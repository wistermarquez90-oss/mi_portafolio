---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import DarkModeToggle from '../components/DarkModeToggle.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import FloatingActions from '../components/FloatingActions.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { 
  title, 
  description = 'Portafolio profesional de Wister Márquez - Economista en Formación | Especialista en E-commerce',
  lang = 'es'
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL || '/';
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Wister Márquez" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  
  <!-- Favicons - Multiple formats for compatibility -->
  <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg?v=2`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}favicon-32x32.svg?v=2`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}apple-touch-icon.svg?v=2`} />
  <link rel="mask-icon" href={`${baseUrl}favicon.svg?v=2`} color="#6a040f" />
  <meta name="msapplication-TileColor" content="#6a040f" />
  <meta name="theme-color" content="#6a040f" />
  
  <title>{title}</title>
  
  <!-- Prefetch para navegación instantánea en móvil -->
  <link rel="prefetch" href={`${baseUrl}`} />
  <link rel="prefetch" href={`${baseUrl}investigacion`} />
  <link rel="prefetch" href={`${baseUrl}pasantias`} />
  <link rel="prefetch" href={`${baseUrl}blog`} />
  <link rel="prefetch" href={`${baseUrl}contacto`} />
  
  <!-- Preconnect para fuentes -->
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  
  <script is:inline>
    // Dark mode initialization - prevent flash
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</head>
<body class="font-body bg-gray-50 text-gray-800 antialiased dark:bg-gray-900 dark:text-gray-100 transition-colors duration-300">
  <ScrollProgress />
  <Navigation />
  <DarkModeToggle />
  <FloatingActions />
  <main class="min-h-screen">
    <slot />
  </main>
  <Footer />
  
  <script>
    // AOS lazy loading - solo carga cuando el usuario no está interactuando con el menú
    const isMobile = window.matchMedia('(pointer: coarse)').matches;
    
    if (!isMobile || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      import('aos').then((AOS) => {
        import('aos/dist/aos.css', { assert: { type: 'css' } }).catch(() => {});
        
        requestIdleCallback(() => {
          AOS.default.init({
            duration: 600,
            easing: 'ease-out-cubic',
            once: true,
            offset: 50,
            disable: window.matchMedia('(prefers-reduced-motion: reduce)').matches
          });
        });
      });
    }
  </script>
</body>
</html>