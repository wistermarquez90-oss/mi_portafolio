---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('pasantias');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const baseUrl = import.meta.env.BASE_URL || '/';
---

<Layout title={`${entry.data.title} | Pasantías`}>
  
  <!-- Hero -->
  <section class="pt-32 pb-12 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto" data-aos="fade-up">
        <a 
          href={`${baseUrl}pasantias`}
          class="inline-flex items-center text-[#ffba08] hover:text-white transition-colors mb-6"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Volver a Pasantías
        </a>
        
        <p class="text-[#ffba08] font-semibold tracking-wider uppercase mb-4">Documentación del Proyecto</p>
        <h1 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">
          {entry.data.title}
        </h1>
        <p class="text-white/80 text-lg">{entry.data.description}</p>
        
        <div class="flex items-center gap-6 mt-6 text-sm text-white/60">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {entry.data.date}
          </span>
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            {entry.data.readingTime}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contenido Markdown -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <article 
          class="prose prose-lg prose-slate max-w-none
            prose-headings:font-display prose-headings:text-[#6a040f] prose-headings:font-bold
            prose-h1:text-4xl prose-h1:mb-8 prose-h1:border-b-2 prose-h1:border-[#ffba08] prose-h1:pb-4
            prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-[#370617]
            prose-h3:text-xl prose-h3:mt-8 prose-h3:text-gray-800
            prose-p:text-gray-700 prose-p:leading-relaxed prose-p:mb-4
            prose-a:text-[#6a040f] prose-a:no-underline hover:prose-a:text-[#ffba08] prose-a:font-medium
            prose-strong:text-[#6a040f] prose-strong:font-bold
            prose-code:text-[#6a040f] prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
            prose-pre:bg-gray-900 prose-pre:text-gray-100 prose-pre:p-4 prose-pre:rounded-lg
            prose-blockquote:border-l-4 prose-blockquote:border-[#ffba08] prose-blockquote:bg-[#6a040f]/5 prose-blockquote:pl-6 prose-blockquote:py-2 prose-blockquote:pr-4 prose-blockquote:rounded-r-lg prose-blockquote:italic prose-blockquote:text-gray-600
            prose-ul:my-6 prose-ul:list-disc prose-ul:pl-6
            prose-ol:my-6 prose-ol:list-decimal prose-ol:pl-6
            prose-li:my-2 prose-li:text-gray-700
            prose-table:my-8 prose-table:w-full prose-table:border-collapse prose-table:shadow-sm prose-table:rounded-lg prose-table:overflow-hidden
            prose-thead:bg-gradient-to-r prose-thead:from-[#6a040f] prose-thead:to-[#370617]
            prose-th:text-white prose-th:font-semibold prose-th:py-3 prose-th:px-4 prose-th:text-left
            prose-td:py-3 prose-td:px-4 prose-td:border-b prose-td:border-gray-200 prose-td:text-gray-700
            prose-tr:even:bg-gray-50 prose-tr:hover:bg-[#6a040f]/5
            prose-hr:my-10 prose-hr:border-gray-200
          "
          data-aos="fade-up"
        >
          <Content />
        </article>
        
        <!-- Navegación -->
        <div class="mt-16 pt-8 border-t-2 border-gray-100" data-aos="fade-up">
          <a 
            href={`${baseUrl}pasantias`}
            class="inline-flex items-center px-6 py-3 bg-[#6a040f] text-white rounded-lg hover:bg-[#370617] transition-colors font-medium"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Volver a Pasantías
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
