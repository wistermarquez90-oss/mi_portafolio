---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
---

<Layout title="Contacto | Wister Márquez">
  
  <!-- Hero -->
  <section class="pt-32 pb-20 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6 text-center" data-aos="fade-up">
      <p class="text-[#ffba08] font-semibold tracking-wider uppercase mb-4">Hablemos</p>
      <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">Contacto</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        ¿Interesado en colaborar o tienes un proyecto en mente? Estoy abierto a nuevas oportunidades.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12">
          
          <!-- Info Column -->
          <div data-aos="fade-up">
            <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-6">Información de Contacto</h2>
            
            <p class="text-gray-600 mb-8">
              Actualmente estoy disponible para proyectos de consultoría, colaboraciones académicas y oportunidades profesionales en el área de economía, análisis de datos y comercio digital.
            </p>

            <div class="space-y-6">
              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#6a040f]/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[#6a040f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">Email</h3>
                  <a href="mailto:wistermarquez90@gmail.com" class="text-[#6a040f] hover:underline">
                    wistermarquez90@gmail.com
                  </a>
                </div>
              </div>

              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#6a040f]/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[#6a040f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">Teléfono</h3>
                  <p class="text-gray-600">+58 414-5716776</p>
                </div>
              </div>

              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#6a040f]/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[#6a040f]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">LinkedIn</h3>
                  <a href="https://www.linkedin.com/in/wister-marquez-duque" target="_blank" class="text-[#6a040f] hover:underline">
                    /wister-marquez-duque
                  </a>
                </div>
              </div>

              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-[#6a040f]/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-[#6a040f]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900">Ubicación</h3>
                  <p class="text-gray-600">Mérida, Venezuela</p>
                </div>
              </div>
            </div>

            
            <div class="mt-8 pt-8 border-t border-gray-200">
              <h3 class="font-semibold text-gray-900 mb-4">Áreas de Interés</h3>
              <div class="flex flex-wrap gap-2">
                {[
                  'Análisis Económico',
                  'Power BI',
                  'Comercio Digital',
                  'Planificación Fiscal',
                  'Capacitación',
                  'Consultoría'
                ].map(area => (
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">{area}</span>
                ))}
              </div>
            </div>
          </div>

          
          <!-- Form Column -->
          <div data-aos="fade-up" data-aos-delay="100">
            <div class="bg-gray-50 rounded-2xl p-8">
              <h2 class="text-2xl font-display font-bold text-[#6a040f] mb-6">Envíame un Mensaje</h2>
              
              <form action="https://formspree.io/f/mwvwdwpk" method="POST" class="space-y-6">
                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Nombre</label>
                  <input 
                    type="text" 
                    name="name" 
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all"
                    placeholder="Tu nombre"
                  />
                </div>

                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                  <input 
                    type="email" 
                    name="email" 
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all"
                    placeholder="tu@email.com"
                  />
                </div>

                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Asunto</label>
                  <select 
                    name="subject"
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all"
                  >
                    <option>Consulta general</option>
                    <option>Proyecto de consultoría</option>
                    <option>Capacitación</option>
                    <option>Oportunidad laboral</option>
                    <option>Colaboración académica</option>
                  </select>
                </div>

                
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Mensaje</label>
                  <textarea 
                    name="message" 
                    rows="5" 
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all resize-none"
                    placeholder="Cuéntame sobre tu proyecto..."
                  ></textarea>
                </div>

                
                <button 
                  type="submit"
                  class="w-full bg-[#6a040f] text-white py-4 rounded-lg font-semibold hover:bg-[#370617] transition-colors flex items-center justify-center gap-2"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                  </svg>
                  Enviar Mensaje
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
