---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import AnimatedCard from '../components/AnimatedCard.astro';
import SignatureFooter from '../components/SignatureFooter.astro';

const baseUrl = import.meta.env.BASE_URL || '/';

const contactInfo = [
  {
    title: "Email",
    value: "wistermarquez90@gmail.com",
    href: "mailto:wistermarquez90@gmail.com",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`
  },
  {
    title: "Teléfono",
    value: "+58 414-5716776",
    href: "tel:+584145716776",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`
  },
  {
    title: "LinkedIn",
    value: "/wister-marquez-duque",
    href: "https://www.linkedin.com/in/wister-marquez-duque",
    icon: `<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`
  },
  {
    title: "Ubicación",
    value: "Mérida, Venezuela",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`
  }
];

const areas = ['Análisis Económico', 'Power BI', 'Comercio Digital', 'Planificación Fiscal', 'Capacitación', 'Consultoría'];
---

<Layout title="Contacto | Wister Márquez">
  
  <PageHeader
    badge="Hablemos"
    title="Contacto"
    description="¿Interesado en colaborar o tienes un proyecto en mente? Estoy abierto a nuevas oportunidades."
  />

  <!-- Contact Section -->
  <section class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12">
          
          <!-- Info Column -->
          <div data-aos="fade-right">
            <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
              Información de Contacto
            </h2>
            
            <p class="text-gray-600 dark:text-gray-300 mb-8 transition-colors">
              Actualmente estoy disponible para proyectos de consultoría, colaboraciones académicas y oportunidades profesionales en el área de economía, análisis de datos y comercio digital.
            </p>

            <div class="space-y-6">
              {contactInfo.map((item, index) => (
                <div 
                  class="contact-item flex items-start gap-4 group"
                  data-aos="fade-right"
                  data-aos-delay={index * 100}
                >
                  <div class="w-12 h-12 bg-[#6a040f]/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-[#6a040f] transition-colors duration-300">
                    <div class="text-[#6a040f] group-hover:text-white transition-colors duration-300" set:html={item.icon} />
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 dark:text-white transition-colors">{item.title}</h3>
                    {item.href ? (
                      <a 
                        href={item.href} 
                        target={item.href.startsWith('http') ? '_blank' : undefined}
                        rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                        class="text-[#6a040f] dark:text-[#ffba08] hover:underline"
                      >
                        {item.value}
                      </a>
                    ) : (
                      <p class="text-gray-600 dark:text-gray-300 transition-colors">{item.value}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700 transition-colors">
              <h3 class="font-semibold text-gray-900 dark:text-white mb-4 transition-colors">
                Áreas de Interés
              </h3>
              <div class="flex flex-wrap gap-2">
                {areas.map((area, index) => (
                  <span 
                    class="area-tag px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-full text-sm transition-colors hover:bg-[#6a040f] hover:text-white dark:hover:bg-[#ffba08] dark:hover:text-[#6a040f] cursor-default"
                    data-aos="zoom-in"
                    data-aos-delay={300 + index * 50}
                  >
                    {area}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Form Column -->
          <div data-aos="fade-left" data-aos-delay="200">
            <AnimatedCard>
              <div class="p-8">
                <h2 class="text-2xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
                  Envíame un Mensaje
                </h2>
                
                <form action="https://formspree.io/f/mwvwdwpk" method="POST" class="space-y-6">
                  
                  <div class="form-group">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2 transition-colors">
                      Nombre
                    </label>
                    <input 
                      type="text"
                      name="name"
                      required
                      class="form-input w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all"
                      placeholder="Tu nombre"
                    />
                  </div>

                  <div class="form-group">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2 transition-colors">
                      Email
                    </label>
                    <input 
                      type="email"
                      name="email"
                      required
                      class="form-input w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all"
                      placeholder="tu@email.com"
                    />
                  </div>

                  <div class="form-group">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2 transition-colors">
                      Asunto
                    </label>
                    <select 
                      name="subject"
                      class="form-input w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all"
                    >
                      <option>Consulta general</option>
                      <option>Proyecto de consultoría</option>
                      <option>Capacitación</option>
                      <option>Oportunidad laboral</option>
                      <option>Colaboración académica</option>
                    </select>
                  </div>

                  <div class="form-group">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2 transition-colors">
                      Mensaje
                    </label>
                    <textarea 
                      name="message"
                      rows="5"
                      required
                      class="form-input w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:border-[#6a040f] focus:ring-2 focus:ring-[#6a040f]/20 outline-none transition-all resize-none"
                      placeholder="Cuéntame sobre tu proyecto..."
                    ></textarea>
                  </div>

                  <button 
                    type="submit"
                    class="submit-btn w-full bg-[#6a040f] text-white py-4 rounded-lg font-semibold hover:bg-[#370617] transition-all duration-300 flex items-center justify-center gap-2 group"
                  >
                    <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                    </svg>
                    Enviar Mensaje
                  </button>
                </form>
              </div>
            </AnimatedCard>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Signature Footer -->
  <section class="py-12 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <SignatureFooter />
    </div>
  </section>

</Layout>

<style>
  .form-input {
    transition: all 0.3s ease;
  }
  
  .form-input:focus {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(106, 4, 15, 0.15);
  }
  
  .form-group {
    opacity: 0;
    animation: formSlideUp 0.5s ease forwards;
  }
  
  .form-group:nth-child(1) { animation-delay: 0.1s; }
  .form-group:nth-child(2) { animation-delay: 0.2s; }
  .form-group:nth-child(3) { animation-delay: 0.3s; }
  .form-group:nth-child(4) { animation-delay: 0.4s; }
  
  @keyframes formSlideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .submit-btn {
    position: relative;
    overflow: hidden;
  }
  
  .submit-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.5s ease;
  }
  
  .submit-btn:hover::before {
    left: 100%;
  }
  
  .area-tag {
    transition: all 0.3s ease;
  }
  
  .area-tag:hover {
    transform: translateY(-2px);
  }
  
  .contact-item {
    transition: transform 0.3s ease;
  }
  
  .contact-item:hover {
    transform: translateX(5px);
  }
</style>
