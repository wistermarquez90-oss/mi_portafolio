---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import AnimatedCard from '../../components/AnimatedCard.astro';
import SignatureFooter from '../../components/SignatureFooter.astro';

const baseUrl = import.meta.env.BASE_URL || '/';

const equipo = [
  { name: 'Wister Márquez', role: 'Economista en Formación', img: `${baseUrl}images/perfil.png` },
  { name: 'Dublymar Gómez', role: 'Economista', img: `${baseUrl}images/dubly.png` },
  { name: 'William Gutierrez', role: 'Economista', img: `${baseUrl}images/william.jpeg` },
  { name: 'Ramon Durán', role: 'Economista en Formación', img: `${baseUrl}images/ramon.jpg` }
];

const metodologia = [
  { step: '1', title: 'Diagnóstico', desc: 'Político, Social, Económico' },
  { step: '2', title: 'Formulación', desc: 'Del Problema' },
  { step: '3', title: 'Definición', desc: 'De Objetivos' },
  { step: '4', title: 'Marco', desc: 'Legal y Teórico' },
  { step: '5', title: 'Propuesta', desc: 'Estratégica' }
];

const diagnostico = [
  { title: 'Político', desc: 'Crisis de gobernabilidad, polarización y fragmentación institucional' },
  { title: 'Económico', desc: 'Hiperinflación crónica, contracción severa del PIB' },
  { title: 'Social', desc: 'Deterioro del nivel de vida, colapso de servicios públicos' }
];

const variables = [
  { label: 'Contracción del PIB', icon: 'trending-down' },
  { label: 'Hiperinflación', icon: 'trending-up' },
  { label: 'Déficit Fiscal', icon: 'scale' },
  { label: 'Deuda Externa', icon: 'currency-dollar' }
];

const objetivos = [
  'Identificar políticas económicas para estabilizar variables macroeconómicas',
  'Ejecutar estrategias económicas para estabilizar variables macroeconómicas',
  'Proponer políticas que promuevan regulación y transparencia de finanzas públicas',
  'Estimular la demanda agregada mediante gasto público de capital',
  'Reestructurar la deuda externa para financiamiento de la nación'
];
---

<Layout title="Política Fiscal | Investigación Académica">
  
  <PageHeader
    badge="8vo Semestre"
    title="Política Fiscal"
    description="Planificación estratégica, presupuesto público y gestión fiscal del Estado"
  />

  <!-- Contenido -->
  <section class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        
        <!-- Sobre la Asignatura -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Sobre la Asignatura
          </h2>
          
          <p class="text-gray-600 dark:text-gray-300 text-lg mb-6 transition-colors">
            En esta cátedra analizamos el papel del Estado en la economía a través del uso de los ingresos y el gasto público. El enfoque principal fue práctico y propositivo, buscando entender la dinámica fiscal como motor de desarrollo.
          </p>
          
          <AnimatedCard>
            <div class="bg-[#6a040f]/5 dark:bg-[#6a040f]/10 border-l-4 border-[#6a040f] p-6 rounded-r-xl">
              <h3 class="font-bold text-[#6a040f] dark:text-[#ffba08] mb-2 flex items-center gap-2">
                <span class="text-2xl">🎯</span>
                Enfoque del Curso
              </h3>
              <p class="text-gray-700 dark:text-gray-300 transition-colors">
                El reto consistió en diagnosticar la situación actual de Venezuela, proponer objetivos macroeconómicos a mediano plazo y diseñar una estrategia de ingresos y gastos (Presupuesto) necesaria para reactivar la economía y garantizar el bienestar social.
              </p>
            </div>
          </AnimatedCard>
        </div>

        <!-- Equipo -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Equipo de Proyecto
          </h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            {equipo.map((member, index) => (
              <AnimatedCard delay={index * 100}>
                <div class="p-6 flex items-center gap-4">
                  <div class="relative">
                    <img 
                      src={member.img} 
                      alt={member.name}
                      class="w-16 h-16 rounded-full object-cover border-2 border-[#6a040f] shadow-md"
                      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                    />
                    <div class="w-16 h-16 bg-gradient-to-br from-[#6a040f] to-[#9f0606] rounded-full flex items-center justify-center text-white font-bold text-xl hidden shadow-md">
                      {member.name.charAt(0)}
                    </div>
                  </div>
                  <div>
                    <h3 class="font-bold text-gray-900 dark:text-white transition-colors">{member.name}</h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400 transition-colors">{member.role}</p>
                  </div>
                </div>
              </AnimatedCard>
            ))}
          </div>
        </div>

        <!-- Metodología -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Metodología Aplicada
          </h2>
          
          <p class="text-gray-600 dark:text-gray-300 mb-8 transition-colors">
            Estructura lógica utilizada para el desarrollo de la Agenda de Reconstrucción Nacional.
          </p>
          
          <div class="grid md:grid-cols-5 gap-4">
            {metodologia.map((item, i) => (
              <div 
                class="relative"
                data-aos="zoom-in"
                data-aos-delay={i * 100}
              >
                <div class="bg-gradient-to-br from-[#6a040f] to-[#9f0606] text-white rounded-xl p-4 text-center shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300">
                  <div class="text-2xl font-bold mb-1">{item.step}</div>
                  <div class="font-semibold text-sm">{item.title}</div>
                  <div class="text-xs text-white/80 mt-1">{item.desc}</div>
                </div>
                
                {i < 4 && (
                  <div class="hidden md:block absolute top-1/2 -right-2 w-4 h-0.5 bg-gradient-to-r from-[#6a040f] to-transparent"></div>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- Caso Venezuela -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Caso de Estudio: Crisis Estructural Venezolana
          </h2>
          
          <div class="grid md:grid-cols-2 gap-8">
            <AnimatedCard>
              <div class="p-6">
                <h3 class="font-bold text-gray-900 dark:text-white mb-4 transition-colors">Diagnóstico Situacional</h3>
                <p class="text-gray-600 dark:text-gray-300 mb-4 transition-colors">
                  El proyecto aborda la profunda crisis que afecta a Venezuela, caracterizada por la erosión de las bases productivas e institucionales.
                </p>
                
                <ul class="space-y-3">
                  {diagnostico.map((item) => (
                    <li class="flex items-start gap-3 group">
                      <span class="w-2 h-2 bg-[#6a040f] rounded-full mt-2 group-hover:scale-150 transition-transform"></span>
                      <span class="text-gray-700 dark:text-gray-300 transition-colors">
                        <strong>Ámbito {item.title}:</strong> {item.desc}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </AnimatedCard>
            
            <div class="bg-gradient-to-br from-[#6a040f] to-[#370617] text-white rounded-2xl p-8 shadow-xl">
              <h3 class="font-bold text-xl mb-6 flex items-center gap-2">
                <svg class="w-6 h-6 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                </svg>
                Variables Macroeconómicas
              </h3>
              
              <ul class="space-y-4">
                {variables.map((variable) => (
                  <li class="flex items-center gap-3 p-3 bg-white/10 rounded-lg hover:bg-white/20 transition-colors">
                    <svg class="w-5 h-5 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    {variable.label}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Objetivos -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Objetivos del Programa Económico
          </h2>
          
          <AnimatedCard>
            <div class="bg-[#6a040f]/5 dark:bg-[#6a040f]/10 border-l-4 border-[#6a040f] p-8 rounded-r-xl mb-8">
              <h3 class="font-bold text-[#6a040f] dark:text-[#ffba08] mb-3">Objetivo General</h3>
              <p class="text-gray-700 dark:text-gray-300 text-lg transition-colors">
                Diseñar un programa para el desarrollo de la nación garantizando la estabilidad macroeconómica y el crecimiento económico sostenible de Venezuela en el periodo 2025-2030.
              </p>
            </div>
          </AnimatedCard>

          <h3 class="font-bold text-gray-900 dark:text-white mb-4 transition-colors">Objetivos Específicos</h3>
          
          <div class="grid md:grid-cols-2 gap-4">
            {objetivos.map((obj, i) => (
              <AnimatedCard delay={i * 100}>
                <div class="flex items-start gap-3 p-4">
                  <div class="w-8 h-8 bg-gradient-to-br from-[#6a040f] to-[#9f0606] text-white rounded-lg flex items-center justify-center flex-shrink-0 font-bold shadow-md">
                    {i + 1}
                  </div>
                  <p class="text-gray-700 dark:text-gray-300 transition-colors">{obj}</p>
                </div>
              </AnimatedCard>
            ))}
          </div>
        </div>

        <!-- Documento -->
        <AnimatedCard>
          <div class="bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-800 dark:to-gray-700 rounded-2xl p-8 text-center transition-colors">
            <div class="w-16 h-16 bg-[#6a040f] rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            
            <h2 class="text-2xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-2">Documento del Proyecto</h2>
            <p class="text-gray-600 dark:text-gray-300 mb-6 transition-colors">Agenda de Reconstrucción Nacional 2025-2030</p>
            
            <a 
              href={`${baseUrl}documentos/plan_nacion.pdf`}
              target="_blank"
              class="inline-flex items-center gap-2 bg-[#6a040f] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#370617] hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              Descargar PDF
            </a>
          </div>
        </AnimatedCard>

      </div>
    </div>
  </section>
  
  <!-- Signature Footer -->
  <section class="py-12 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <SignatureFooter />
    </div>
  </section>

</Layout>
