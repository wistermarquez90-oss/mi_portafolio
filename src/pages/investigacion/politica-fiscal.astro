---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Política Fiscal | Investigación Académica">
  
  <!-- Hero --
  <section class="pt-32 pb-20 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6">
      <div class="text-center" data-aos="fade-up">
        <p class="text-[#ffba08] font-semibold tracking-wider uppercase mb-4">8vo Semestre</p>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">Política Fiscal</h1>
        <p class="text-xl text-white/80 max-w-3xl mx-auto">
          Planificación estratégica, presupuesto público y gestión fiscal del Estado
        </p>
      </div>
    </div>
  </section>

  <!-- Contenido --
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        
        <!-- Sobre la Asignatura --
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-6">Sobre la Asignatura</h2>
          
          <p class="text-gray-600 text-lg mb-6">
            En esta cátedra analizamos el papel del Estado en la economía a través del uso de los ingresos y el gasto público. El enfoque principal fue práctico y propositivo, buscando entender la dinámica fiscal como motor de desarrollo.
          </p>
          
          <div class="bg-[#6a040f]/5 border-l-4 border-[#6a040f] p-6 rounded-r-xl">
            <h3 class="font-bold text-[#6a040f] mb-2">🎯 Enfoque del Curso</h3>
            <p class="text-gray-700">
              El reto consistió en diagnosticar la situación actual de Venezuela, proponer objetivos macroeconómicos a mediano plazo y diseñar una estrategia de ingresos y gastos (Presupuesto) necesaria para reactivar la economía y garantizar el bienestar social.
            </p>
          </div>
        </div>

        <!-- Equipo --
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-6">Equipo de Proyecto</h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            {[
              { name: 'Wister Márquez', role: 'Economista en Formación', img: '/img/perfil.png' },
              { name: 'Dublymar Gómez', role: 'Economista', img: '/img/Dubly.png' },
              { name: 'William Gutierrez', role: 'Economista', img: '/img/william.jpeg' },
              { name: 'Ramon Durán', role: 'Economista en Formación', img: '/img/Aguacate.jpg' }
            ].map(member => (
              <div class="bg-gray-50 rounded-xl p-6 flex items-center gap-4">
                <div class="w-16 h-16 bg-[#6a040f] rounded-full flex items-center justify-center text-white font-bold text-xl">
                  {member.name.charAt(0)}
                </div>
                <div>
                  <h3 class="font-bold text-gray-900">{member.name}</h3>
                  <p class="text-sm text-gray-600">{member.role}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Metodología --
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-6">Metodología Aplicada</h2>
          
          <p class="text-gray-600 mb-8">Estructura lógica utilizada para el desarrollo de la Agenda de Reconstrucción Nacional.</p>
          
          <div class="grid md:grid-cols-5 gap-4">
            {[
              { step: '1', title: 'Diagnóstico', desc: 'Político, Social, Económico' },
              { step: '2', title: 'Formulación', desc: 'Del Problema' },
              { step: '3', title: 'Definición', desc: 'De Objetivos' },
              { step: '4', title: 'Marco', desc: 'Legal y Teórico' },
              { step: '5', title: 'Propuesta', desc: 'Estratégica' }
            ].map((item, i) => (
              <div class="relative">
                <div class="bg-[#6a040f] text-white rounded-xl p-4 text-center">
                  <div class="text-2xl font-bold mb-1">{item.step}</div>
                  <div class="font-semibold">{item.title}</div>
                  <div class="text-xs text-white/80">{item.desc}</div>
                </div>
                {i < 4 && (
                  <div class="hidden md:block absolute top-1/2 -right-2 w-4 h-0.5 bg-[#6a040f]/30"></div>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- Caso Venezuela --
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-6">Caso de Estudio: Crisis Estructural Venezolana</h2>
          
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="font-bold text-gray-900 mb-4">Diagnóstico Situacional</h3>
              <p class="text-gray-600 mb-4">
                El proyecto aborda la profunda crisis que afecta a Venezuela, caracterizada por la erosión de las bases productivas e institucionales.
              </p>
              
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-[#6a040f] rounded-full mt-2"></span>
                  <span><strong>Ámbito Político:</strong> Crisis de gobernabilidad, polarización y fragmentación institucional</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-[#6a040f] rounded-full mt-2"></span>
                  <span><strong>Ámbito Económico:</strong> Hiperinflación crónica, contracción severa del PIB</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="w-2 h-2 bg-[#6a040f] rounded-full mt-2"></span>
                  <span><strong>Ámbito Social:</strong> Deterioro del nivel de vida, colapso de servicios públicos</span>
                </li>
              </ul>
            </div>
            
            <div class="bg-[#6a040f] text-white rounded-2xl p-8">
              <h3 class="font-bold text-xl mb-6 flex items-center gap-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                </svg>
                Variables Macroeconómicas
              </h3>
              
              <ul class="space-y-4">
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
                  Contracción del PIB
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
                  </svg>
                  Hiperinflación
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
                  </svg>
                  Déficit Fiscal
                </li>
                <li class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  Deuda Externa
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Objetivos --
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-6">Objetivos del Programa Económico</h2>
          
          <div class="bg-[#6a040f]/5 border-l-4 border-[#6a040f] p-8 rounded-r-xl mb-8">
            <h3 class="font-bold text-[#6a040f] mb-3">Objetivo General</h3>
            <p class="text-gray-700 text-lg">
              Diseñar un programa para el desarrollo de la nación garantizando la estabilidad macroeconómica y el crecimiento económico sostenible de Venezuela en el periodo 2025-2030.
            </p>
          </div>

          <h3 class="font-bold text-gray-900 mb-4">Objetivos Específicos</h3>
          
          <div class="grid md:grid-cols-2 gap-4">
            {[
              'Identificar políticas económicas para estabilizar variables macroeconómicas',
              'Ejecutar estrategias económicas para estabilizar variables macroeconómicas',
              'Proponer políticas que promuevan regulación y transparencia de finanzas públicas',
              'Estimular la demanda agregada mediante gasto público de capital',
              'Reestructurar la deuda externa para financiamiento de la nación'
            ].map((obj, i) => (
              <div class="flex items-start gap-3 bg-gray-50 p-4 rounded-lg">
                <div class="w-8 h-8 bg-[#6a040f] text-white rounded-lg flex items-center justify-center flex-shrink-0 font-bold">
                  {i + 1}
                </div>
                <p class="text-gray-700">{obj}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Documento --
        <div class="bg-gray-50 rounded-2xl p-8 text-center" data-aos="fade-up">
          <h2 class="text-2xl font-display font-bold text-[#6a040f] mb-4">Documento del Proyecto</h2>
          <p class="text-gray-600 mb-6">Agenda de Reconstrucción Nacional 2025-2030</p>
          
          <a 
            href="/documentos/plan_nacion.pdf" 
            target="_blank"
            class="inline-flex items-center gap-2 bg-[#6a040f] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#370617] transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Descargar PDF
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>
