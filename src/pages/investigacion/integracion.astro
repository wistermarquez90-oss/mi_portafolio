---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import AnimatedCard from '../../components/AnimatedCard.astro';
import SignatureFooter from '../../components/SignatureFooter.astro';

const baseUrl = import.meta.env.BASE_URL || '/';

const unidades = [
  { unit: 'I', title: 'Integración Económica', desc: 'Conceptos, fases y teorías fundamentales' },
  { unit: 'II', title: 'Experiencias Latinoamericanas', desc: 'MCCA, ALALC, ALADI y CARICOM' },
  { unit: 'III', title: 'Integración Antisistémica', desc: 'Conceptos y el ALBA-TCP' },
  { unit: 'IV', title: 'Integración en América del Sur', desc: 'Comunidad Andina (CAN) y Mercosur' },
  { unit: 'V', title: 'Integración y Fronteras', desc: 'Política exterior y fronteras de Venezuela' }
];

const bloques = [
  { name: 'MCCA', full: 'Mercado Común Centroamericano', region: 'Centroamérica', color: 'from-blue-500 to-blue-600' },
  { name: 'CAN', full: 'Comunidad Andina', region: 'Países Andinos', color: 'from-[#6a040f] to-[#9f0606]' },
  { name: 'MERCOSUR', full: 'Mercado Común del Sur', region: 'Cono Sur', color: 'from-green-500 to-green-600' },
  { name: 'CARICOM', full: 'Comunidad del Caribe', region: 'Caribe', color: 'from-yellow-500 to-yellow-600' }
];

const esquema = [
  { num: '1', title: 'Fundamentos', desc: 'Pensamiento CEPAL - Raúl Prebisch, Modelo ISI, Desarrollo "hacia adentro", Protección industrial', highlight: false },
  { num: '2', title: 'Antecedentes', desc: 'ALALC (1960) - Fracaso por burocracia y falta de plazos claros', highlight: false },
  { num: '3', title: 'Marco Actual', desc: 'ALADI (1980) - Enfoque pragmático y flexible. Mecanismos PAR y Acuerdos Regionales', highlight: false },
  { num: '4', title: 'Bloques Actuales', desc: 'MCCA, CAN, MERCOSUR, CARICOM - Sistema de integración latinoamericano', highlight: true }
];

const documentos = [
  { title: 'Trabajo Final: Integración', desc: 'Análisis completo de bloques económicos', href: baseUrl + 'documentos/integracion.pdf', icon: 'file' },
  { title: 'Ensayo: Mercosur', desc: 'Análisis del Mercado Común del Sur', href: baseUrl + 'documentos/ensayo_mercosur.pdf', icon: 'file' },
  { title: 'Cartografía', desc: 'Mapa de integración económica en alta calidad', href: baseUrl + 'documentos/cartografia.pdf', icon: 'map' }
];
---

<Layout title="Integración Económica | Investigación Académica">
  
  <PageHeader
    badge="9no Semestre"
    title="Integración Económica"
    description="Estudio de bloques económicos y acuerdos comerciales en América Latina"
  />

  <section class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        
        <div class="mb-16" data-aos="fade-up">
          <AnimatedCard>
            <div class="bg-[#6a040f]/5 dark:bg-[#6a040f]/10 border-l-4 border-[#6a040f] p-6 rounded-r-xl mb-8">
              <p class="text-lg text-gray-700 dark:text-gray-300">
                <strong class="text-[#6a040f] dark:text-[#ffba08]">Objetivo General:</strong> Estudiar los efectos de la Integración Económica en el desenvolvimiento de las economías de los países que firman acuerdos de comercio preferencial.
              </p>
            </div>
          </AnimatedCard>

          <h3 class="font-bold text-gray-900 dark:text-white mb-4 transition-colors">Contenido Programático</h3>
          
          <div class="grid md:grid-cols-2 gap-4">
            {unidades.map((item, index) => (
              <AnimatedCard delay={index * 100}>
                <div class="p-4 border-l-4 border-[#6a040f]">
                  <span class="text-[#6a040f] dark:text-[#ffba08] font-bold text-sm">UNIDAD {item.unit}</span>
                  <h4 class="font-bold text-gray-900 dark:text-white transition-colors">{item.title}</h4>
                  <p class="text-sm text-gray-600 dark:text-gray-400 transition-colors">{item.desc}</p>
                </div>
              </AnimatedCard>
            ))}
          </div>
        </div>

        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Bloques Económicos Latinoamericanos
          </h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
            {bloques.map((bloque, index) => (
              <div 
                class={"bg-gradient-to-br text-white rounded-xl p-6 text-center shadow-lg hover:shadow-xl hover:scale-105 transition-all duration-300 " + bloque.color}
                data-aos="zoom-in"
                data-aos-delay={index * 100}
              >
                <div class="text-2xl font-bold mb-2">{bloque.name}</div>
                <p class="text-sm text-white/80">{bloque.full}</p>
                <span class="inline-block mt-3 px-3 py-1 bg-white/20 rounded-full text-xs">
                  {bloque.region}
                </span>
              </div>
            ))}
          </div>
        </div>

        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Esquema de Integración Económica
          </h2>
          
          <AnimatedCard>
            <div class="bg-white dark:bg-gray-800 border-4 border-[#6a040f] rounded-2xl p-8">
              <div class="space-y-6">
                {esquema.map((item, index) => (
                  <div
                    class="flex items-start gap-4 group"
                    data-aos="fade-right"
                    data-aos-delay={index * 150}
                  >
                    <div class={"w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 transition-transform " + (item.highlight ? "bg-[#ffba08]" : "bg-[#6a040f]")}>
                      <span class={"font-bold text-lg " + (item.highlight ? "text-[#6a040f]" : "text-white")}>{item.num}</span>
                    </div>
                    <div class="flex-1">
                      <h3 class="font-bold text-gray-900 dark:text-white transition-colors">{item.title}</h3>
                      <p class="text-gray-600 dark:text-gray-300 transition-colors">{item.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </AnimatedCard>
        </div>

        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Biblioteca de Investigación
          </h2>
          
          <div class="space-y-4">
            {documentos.map((doc, index) => (
              <AnimatedCard delay={index * 100}>
                <a href={doc.href} target="_blank" class="block">
                  <div class="flex items-center justify-between p-6 group">
                    <div class="flex items-center gap-4">
                      <div class="w-12 h-12 bg-gradient-to-br from-[#6a040f] to-[#9f0606] rounded-xl flex items-center justify-center shadow-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          {doc.icon === 'map' ? (
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 7m0 13V7"/>
                          ) : (
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                          )}
                        </svg>
                      </div>
                      <div>
                        <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-[#6a040f] dark:group-hover:text-[#ffba08] transition-colors">
                          {doc.title}
                        </h3>
                        <p class="text-sm text-gray-600 dark:text-gray-400 transition-colors">{doc.desc}</p>
                      </div>
                    </div>
                    <svg class="w-6 h-6 text-gray-400 group-hover:text-[#6a040f] dark:group-hover:text-[#ffba08] transition-colors group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                </a>
              </AnimatedCard>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>
  
  <section class="py-12 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <SignatureFooter />
    </div>
  </section>

</Layout>
