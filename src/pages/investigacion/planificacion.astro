---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import AnimatedCard from '../../components/AnimatedCard.astro';
import SignatureFooter from '../../components/SignatureFooter.astro';

const baseUrl = import.meta.env.BASE_URL || '/';

const metodologia = [
  { num: '01', title: 'Horizonte', desc: '1 Año' },
  { num: '02', title: 'Principios', desc: 'Corporativos' },
  { num: '03', title: 'Diagnóstico', desc: 'FODA' },
  { num: '04', title: 'Direccionamiento', desc: 'Visión/Misión' },
  { num: '05', title: 'Proyección', desc: 'Estratégica' },
  { num: '06', title: 'Diseño', desc: 'de Planes' },
  { num: '07', title: 'Monitoreo', desc: 'y Evaluación' }
];

const leyes = [
  { title: 'Constitución de la República (CRBV)', art: 'Artículo 315', desc: 'En los presupuestos públicos anuales de gastos... se establecerá de manera clara, para cada crédito presupuestario, el objetivo específico a que esté dirigido, los resultados concretos que se espera obtener...' },
  { title: 'Ley Orgánica de Planificación Pública (LOPPP)', art: 'Artículo 52', desc: 'Los planes operativos son aquellos formulados por los órganos y entes del Poder Público... con la finalidad de concretar los proyectos, recursos, objetivos y metas, trazados en los planes estratégicos.' }
];

const documentos = [
  { label: 'Constitución CRBV', href: `${baseUrl}documentos/constitucion_venezuela.pdf` },
  { label: 'Ley LOPPP', href: `${baseUrl}documentos/ley_planificacion.pdf` },
  { label: 'Ley Corpoandes', href: `${baseUrl}documentos/ley_creacion_corpoandes.pdf` }
];
---

<Layout title="Planificación Económica | Investigación Académica">
  
  <PageHeader
    badge="9no Semestre"
    title="Planificación Económica"
    description="Formulación del Plan Operativo Anual (POA) y gestión del presupuesto público"
  />

  <section class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Ficha Académica
          </h2>
          
          <p class="text-gray-600 dark:text-gray-300 text-lg mb-6 transition-colors">
            Esta asignatura se centra en el estudio y aplicación de las herramientas de planificación estratégica en el sector público venezolano. A lo largo del semestre, analizamos el marco jurídico vigente para comprender cómo se estructura el presupuesto nacional.
          </p>
          
          <AnimatedCard>
            <div class="bg-[#6a040f]/5 dark:bg-[#6a040f]/10 border-l-4 border-[#6a040f] p-6 rounded-r-xl">
              <h3 class="font-bold text-[#6a040f] dark:text-[#ffba08] mb-2 flex items-center gap-2">
                <span class="text-2xl">🎯</span>
                Objetivo General
              </h3>
              <p class="text-gray-700 dark:text-gray-300 transition-colors">
                Desarrollar las competencias necesarias para la formulación del <strong>Plan Operativo Anual (POA)</strong> de una institución pública real. El proceso abarcó desde el análisis situacional (FODA) hasta la asignación de recursos financieros basados en metas cuantificables.
              </p>
            </div>
          </AnimatedCard>
        </div>

        <!-- Metodología -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Metodología del POA
          </h2>
          
          <div class="grid md:grid-cols-7 gap-3">
            {metodologia.map((item, i) => (
              <div 
                class={`${i === 6 ? 'bg-gradient-to-br from-[#6a040f] to-[#9f0606] text-white' : 'bg-white dark:bg-gray-800 border-2 border-[#6a040f] text-[#6a040f] dark:text-[#ffba08]'} rounded-xl p-4 text-center shadow-md hover:shadow-xl hover:scale-105 transition-all duration-300`}
                data-aos="zoom-in"
                data-aos-delay={i * 50}
              >
                <div class="text-2xl font-bold mb-1">{item.num}</div>
                <div class="font-semibold text-sm">{item.title}</div>
                <div class={`text-xs ${i === 6 ? 'text-white/80' : 'text-gray-600 dark:text-gray-400'}`}>{item.desc}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Caso Corpoandes -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Caso de Estudio: Corpoandes
          </h2>
          
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <AnimatedCard>
              <div class="p-6">
                <p class="text-gray-600 dark:text-gray-300 mb-6 transition-colors">
                  La aplicación práctica de esta metodología se realizó en la <strong>Corporación de los Andes (CORPOANDES)</strong>. El trabajo consistió en analizar a profundidad su Ley de Creación para alinear sus objetivos históricos con las nuevas exigencias de la Planificación Pública.
                </p>
                
                <a 
                  href={`${baseUrl}documentos/poa_corpoandes.pdf`}
                  target="_blank"
                  class="inline-flex items-center gap-2 bg-[#6a040f] text-white px-6 py-3 rounded-lg font-semibold hover:bg-[#370617] hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  Ver POA Completo
                </a>
              </div>
            </AnimatedCard>
            
            <div class="bg-gradient-to-br from-[#6a040f] to-[#370617] text-white rounded-2xl p-8 shadow-xl">
              <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h3 class="font-bold text-xl mb-3">Enfoque del POA</h3>
              <p class="text-white/90 italic">
                "El POA no es solo un requisito legal, es la herramienta de navegación que conecta los recursos actuales (Diagnóstico) con la visión futura (Proyección) a través de acciones medibles (Monitoreo)."
              </p>
            </div>
          </div>
        </div>

        <!-- Marco Legal -->
        <div class="mb-16" data-aos="fade-up">
          <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-6">
            Base Jurídica
          </h2>
          
          <div class="space-y-4">
            {leyes.map((ley, index) => (
              <AnimatedCard delay={index * 100}>
                <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 transition-colors">
                  <h3 class="font-bold text-[#6a040f] dark:text-[#ffba08] mb-2">{ley.title}</h3>
                  <blockquote class="text-gray-700 dark:text-gray-300 italic border-l-4 border-[#6a040f] pl-4 transition-colors">
                    "{ley.desc}"
                  </blockquote>
                  <p class="text-right text-sm text-[#6a040f] dark:text-[#ffba08] mt-2">— {ley.art}</p>
                </div>
              </AnimatedCard>
            ))}
          </div>

          <div class="mt-8 flex flex-wrap gap-4">
            {documentos.map((doc, index) => (
              <a 
                href={doc.href}
                target="_blank"
                class="inline-flex items-center gap-2 px-4 py-2 border-2 border-[#6a040f] text-[#6a040f] dark:text-[#ffba08] dark:border-[#ffba08] rounded-lg hover:bg-[#6a040f] hover:text-white dark:hover:bg-[#ffba08] dark:hover:text-[#6a040f] transition-all duration-300"
                data-aos="fade-up"
                data-aos-delay={index * 100}
              >
                {doc.label}
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>
  
  <!-- Signature Footer -->
  <section class="py-12 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <SignatureFooter />
    </div>
  </section>

</Layout>
