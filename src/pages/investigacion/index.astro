---
import Layout from '../../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
---

<Layout title="Investigación Académica | Wister Márquez">
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6">
      <div class="text-center" data-aos="fade-up">
        <p class="text-[#ffba08] font-semibold tracking-wider uppercase mb-4">Formación Universitaria</p>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">
          Investigación Académica
        </h1>
        <p class="text-xl text-white/80 max-w-3xl mx-auto">
          Trabajos realizados durante la carrera de Economía en la Universidad de Los Andes
        </p>
      </div>
    </div>
  </section>

  <!-- Asignaturas Grid -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-4">Asignaturas Destacadas</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Explora los proyectos desarrollados en las asignaturas de últimos semestres
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Política Fiscal -->
        <a href={`${baseUrl}investigacion/politica-fiscal`} class="group" data-aos="fade-up">
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-300 h-full">
            <div class="h-2 bg-[#6a040f]"></div>
            <div class="p-8">
              <div class="w-16 h-16 bg-[#6a040f]/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[#6a040f] transition-colors">
                <svg class="w-8 h-8 text-[#6a040f] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
              </div>
              <p class="text-sm text-[#6a040f] font-semibold mb-2">8vo Semestre</p>
              <h3 class="text-2xl font-display font-bold text-gray-900 mb-4">Política Fiscal</h3>
              <p class="text-gray-600 mb-6">
                Planificación estratégica, presupuesto público y gestión fiscal del Estado. Agenda de Reconstrucción Nacional 2025-2030.
              </p>
              <span class="inline-flex items-center text-[#6a040f] font-semibold">
                Ver proyecto 
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Planificación Económica -->
        <a href={`${baseUrl}investigacion/planificacion`} class="group" data-aos="fade-up" data-aos-delay="100">
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-300 h-full">
            <div class="h-2 bg-[#6a040f]"></div>
            <div class="p-8">
              <div class="w-16 h-16 bg-[#6a040f]/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[#6a040f] transition-colors">
                <svg class="w-8 h-8 text-[#6a040f] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                </svg>
              </div>
              <p class="text-sm text-[#6a040f] font-semibold mb-2">9no Semestre</p>
              <h3 class="text-2xl font-display font-bold text-gray-900 mb-4">Planificación Económica</h3>
              <p class="text-gray-600 mb-6">
                Formulación del Plan Operativo Anual (POA) aplicado al caso real de Corpoandes con metodología FODA.
              </p>
              <span class="inline-flex items-center text-[#6a040f] font-semibold">
                Ver proyecto 
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </div>
          </div>
        </a>

        <!-- Integración Económica -->
        <a href={`${baseUrl}investigacion/integracion`} class="group" data-aos="fade-up" data-aos-delay="200">
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-300 h-full">
            <div class="h-2 bg-[#6a040f]"></div>
            <div class="p-8">
              <div class="w-16 h-16 bg-[#6a040f]/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[#6a040f] transition-colors">
                <svg class="w-8 h-8 text-[#6a040f] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <p class="text-sm text-[#6a040f] font-semibold mb-2">9no Semestre</p>
              <h3 class="text-2xl font-display font-bold text-gray-900 mb-4">Integración Económica</h3>
              <p class="text-gray-600 mb-6">
                Estudio de bloques económicos latinoamericanos: MCCA, CAN, MERCOSUR, CARICOM, ALALC, ALADI.
              </p>
              <span class="inline-flex items-center text-[#6a040f] font-semibold">
                Ver proyecto 
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Características Section -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div data-aos="fade-up">
          <div class="text-4xl font-bold text-[#6a040f] mb-2">3</div>
          <p class="text-gray-600">Asignaturas</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="100">
          <div class="text-4xl font-bold text-[#6a040f] mb-2">15+</div>
          <p class="text-gray-600">Documentos</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="200">
          <div class="text-4xl font-bold text-[#6a040f] mb-2">10+</div>
          <p class="text-gray-600">Fuentes Legales</p>
        </div>
        <div data-aos="fade-up" data-aos-delay="300">
          <div class="text-4xl font-bold text-[#6a040f] mb-2">4</div>
          <p class="text-gray-600">Bloques Económicos</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-[#6a040f]">
    <div class="container mx-auto px-6 text-center">
      <div data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">
          ¿Interesado en mi trabajo académico?
        </h2>
        <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto">
          Puedo aplicar estas metodologías en proyectos de planificación y análisis fiscal para tu organización.
        </p>
        <a 
          href={`${baseUrl}contacto`} 
          class="inline-block bg-[#ffba08] text-[#6a040f] px-8 py-4 rounded-full font-semibold hover:bg-white transition-colors"
        >
          Contactar
        </a>
      </div>
    </div>
  </section>

</Layout>
