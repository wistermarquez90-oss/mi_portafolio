---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import AnimatedCard from '../../components/AnimatedCard.astro';
import SignatureFooter from '../../components/SignatureFooter.astro';

const baseUrl = import.meta.env.BASE_URL || '/';

const subjects = [
  {
    href: `${baseUrl}investigacion/politica-fiscal`,
    semester: "8vo Semestre",
    title: "Política Fiscal",
    description: "Planificación estratégica, presupuesto público y gestión fiscal del Estado. Agenda de Reconstrucción Nacional 2025-2030.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`
  },
  {
    href: `${baseUrl}investigacion/planificacion`,
    semester: "9no Semestre",
    title: "Planificación Económica",
    description: "Formulación del Plan Operativo Anual (POA) aplicado al caso real de Corpoandes con metodología FODA.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>`,
    delay: 100
  },
  {
    href: `${baseUrl}investigacion/integracion`,
    semester: "9no Semestre",
    title: "Integración Económica",
    description: "Estudio de bloques económicos latinoamericanos: MCCA, CAN, MERCOSUR, CARICOM, ALALC, ALADI.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    delay: 200
  }
];

const stats = [
  { value: "3", label: "Asignaturas", delay: 0 },
  { value: "15+", label: "Documentos", delay: 100 },
  { value: "10+", label: "Fuentes Legales", delay: 200 },
  { value: "4", label: "Bloques Económicos", delay: 300 }
];
---

<Layout title="Investigación Académica | Wister Márquez">
  
  <PageHeader
    badge="Formación Universitaria"
    title="Investigación Académica"
    description="Trabajos realizados durante la carrera de Economía en la Universidad de Los Andes"
  />

  <!-- Asignaturas Grid -->
  <section class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16" data-aos="fade-up">
        <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-4">
          Asignaturas Destacadas
        </h2>
        <p class="text-gray-600 dark:text-gray-300 max-w-2xl mx-auto transition-colors duration-300">
          Explora los proyectos desarrollados en las asignaturas de últimos semestres
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {subjects.map((subject) => (
          <AnimatedCard href={subject.href} delay={subject.delay} class="h-full">
            <div class="h-full flex flex-col">
              <div class="h-2 bg-[#6a040f]"></div>
              <div class="p-8 flex-1 flex flex-col">
                <div class="w-16 h-16 bg-[#6a040f]/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-[#6a040f] transition-colors duration-300">
                  <div class="text-[#6a040f] group-hover:text-white transition-colors duration-300" set:html={subject.icon} />
                </div>
                <p class="text-sm text-[#6a040f] dark:text-[#ffba08] font-semibold mb-2">{subject.semester}</p>
                <h3 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-4 transition-colors">
                  {subject.title}
                </h3>
                <p class="text-gray-600 dark:text-gray-300 mb-6 transition-colors flex-1">
                  {subject.description}
                </p>
                <span class="inline-flex items-center text-[#6a040f] dark:text-[#ffba08] font-semibold group-hover:translate-x-2 transition-transform">
                  Ver proyecto 
                  <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </span>
              </div>
            </div>
          </AnimatedCard>
        ))}
      </div>
    </div>
  </section>

  <!-- Características Section -->
  <section class="py-20 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        {stats.map((stat) => (
          <div data-aos="zoom-in" data-aos-delay={stat.delay}>
            <div class="text-5xl font-bold text-[#6a040f] dark:text-[#ffba08] mb-2 counter-animation">
              {stat.value}
            </div>
            <p class="text-gray-600 dark:text-gray-300 transition-colors font-medium">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-gradient-to-br from-[#6a040f] to-[#370617] relative overflow-hidden">
    <!-- Background animation -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-64 h-64 bg-[#ffba08]/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#9f0606]/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 0.5s;"></div>
    </div>
    
    <div class="container mx-auto px-6 text-center relative z-10">
      <div data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">
          ¿Interesado en mi trabajo académico?
        </h2>
        <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto">
          Puedo aplicar estas metodologías en proyectos de planificación y análisis fiscal para tu organización.
        </p>
        <a 
          href={`${baseUrl}contacto`} 
          class="inline-flex items-center gap-2 bg-[#ffba08] text-[#6a040f] px-8 py-4 rounded-full font-semibold hover:bg-white hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          Contactar
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Signature Footer -->
  <section class="py-12 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <SignatureFooter />
    </div>
  </section>

</Layout>

<style>
  .counter-animation {
    animation: counterPulse 2s ease-in-out infinite;
  }
  
  @keyframes counterPulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }
</style>
