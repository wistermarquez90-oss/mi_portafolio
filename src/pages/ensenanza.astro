---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import AnimatedCard from '../components/AnimatedCard.astro';
import SignatureFooter from '../components/SignatureFooter.astro';

const baseUrl = import.meta.env.BASE_URL || '/';

const stats = [
  { value: "4", label: "Módulos", delay: 0 },
  { value: "6", label: "Sesiones", delay: 100 },
  { value: "13", label: "Estudiantes", delay: 200 }
];

const organismos = ['Banco Mundial', 'CEPAL', 'FMI', 'UN Comtrade', 'ACNUR', 'OIM'];

const funcionesExcel = ['BUSCARV/XLOOKUP', 'Tablas Dinámicas', 'Gráficos Avanzados', 'Validación de Datos', 'Formato Condicional'];

const modulosAPA = [
  { num: "1", title: "Citas Textuales y Paráfrasis", desc: "Citas directas cortas/largas, parafraseo vs. plagio" },
  { num: "2", title: "Referencias Bibliográficas", desc: "Libros, artículos, documentos institucionales" },
  { num: "3", title: "Tablas y Figuras", desc: "Formatos de tablas, notas al pie, numeración" },
  { num: "4", title: "Revisión Final", desc: "Múltiples autores, fuentes secundarias" }
];

const pasosLimpieza = [
  { num: "1", title: "Importación", desc: "Revisión inicial de formatos y columnas" },
  { num: "2", title: "Limpieza", desc: "Eliminar duplicados, estandarizar fechas" },
  { num: "3", title: "Validación", desc: "Verificar rangos y validación cruzada" },
  { num: "4", title: "Transformación", desc: "Variables derivadas y agregación" }
];
---

<Layout title="Capacitación en Investigación | Wister Márquez">
  
  <PageHeader
    badge="Programa de Formación"
    title="Capacitación en Investigación Económica"
    description="Formación práctica para auxiliares de investigación en Economía Internacional"
  />

  <!-- Introducción -->
  <section class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <AnimatedCard>
          <div class="bg-[#6a040f]/5 dark:bg-[#6a040f]/10 border-l-4 border-[#6a040f] p-8 rounded-r-xl">
            <h2 class="text-2xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-4">
              Programa de Formación
            </h2>
            <p class="text-lg text-gray-700 dark:text-gray-300 mb-4 transition-colors">
              Diseñé un programa de capacitación para estudiantes de <strong>Economía Internacional</strong> que trabajarán como auxiliares de investigación en proyectos de análisis económico.
            </p>
            
            <div class="grid md:grid-cols-3 gap-4 mt-6">
              {stats.map((stat) => (
                <div 
                  class="bg-white dark:bg-gray-800 p-4 rounded-lg shadow-sm text-center transition-colors hover:shadow-md hover:scale-105 transition-all duration-300"
                  data-aos="zoom-in"
                  data-aos-delay={stat.delay}
                >
                  <div class="text-3xl font-bold text-[#6a040f] dark:text-[#ffba08]">{stat.value}</div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 transition-colors">{stat.label}</p>
                </div>
              ))}
            </div>
          </div>
        </AnimatedCard>

        <!-- Módulos -->
        <h3 class="text-2xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-8 mt-12" data-aos="fade-up">
          Módulos del Curso
        </h3>

        <div class="space-y-8">
          
          <!-- Módulo 1 -->
          <AnimatedCard delay={0}>
            <div>
              <div class="bg-[#6a040f] px-6 py-4">
                <h4 class="text-white font-bold text-lg">Módulo 1: Búsqueda de Bases de Datos Económicas</h4>
              </div>
              <div class="p-6">
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h5 class="font-semibold text-gray-900 dark:text-white mb-3 transition-colors">Fuentes Oficiales Venezuela:</h5>
                    <ul class="text-gray-600 dark:text-gray-300 space-y-1 text-sm transition-colors">
                      <li>• Banco Central de Venezuela (BCV)</li>
                      <li>• Instituto Nacional de Estadística (INE)</li>
                      <li>• Gaceta Oficial - Normativas</li>
                    </ul>
                  </div>
                  
                  <div>
                    <h5 class="font-semibold text-gray-900 dark:text-white mb-3 transition-colors">Fuentes Oficiales Colombia:</h5>
                    <ul class="text-gray-600 dark:text-gray-300 space-y-1 text-sm transition-colors">
                      <li>• DANE - Estadísticas nacionales</li>
                      <li>• Banco de la República</li>
                      <li>• DIAN - Comercio exterior</li>
                      <li>• Migración Colombia</li>
                    </ul>
                  </div>
                </div>
                
                <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700">
                  <h5 class="font-semibold text-gray-900 dark:text-white mb-3 transition-colors">Organismos Internacionales:</h5>
                  <div class="flex flex-wrap gap-2">
                    {organismos.map((org, index) => (
                      <span 
                        class="org-tag px-3 py-1 bg-[#6a040f]/10 text-[#6a040f] dark:text-[#ffba08] dark:bg-[#ffba08]/10 rounded-full text-sm hover:bg-[#6a040f] hover:text-white transition-all duration-300 cursor-default"
                        data-aos="fade-up"
                        data-aos-delay={index * 50}
                      >
                        {org}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </AnimatedCard>

          <!-- Módulo 2 -->
          <AnimatedCard delay={100}>
            <div>
              <div class="bg-[#6a040f] px-6 py-4">
                <h4 class="text-white font-bold text-lg">Módulo 2: Limpieza de Datos en Excel</h4>
              </div>
              <div class="p-6">
                <div class="grid md:grid-cols-4 gap-4">
                  {pasosLimpieza.map((paso, index) => (
                    <div 
                      class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl transition-colors hover:bg-[#6a040f]/5 dark:hover:bg-[#6a040f]/20 transition-all duration-300"
                      data-aos="fade-up"
                      data-aos-delay={index * 100}
                    >
                      <div class="w-12 h-12 bg-[#6a040f] rounded-full flex items-center justify-center mx-auto mb-3 shadow-lg">
                        <span class="text-white font-bold">{paso.num}</span>
                      </div>
                      <h5 class="font-semibold text-gray-900 dark:text-white mb-2 transition-colors">{paso.title}</h5>
                      <p class="text-sm text-gray-600 dark:text-gray-300 transition-colors">{paso.desc}</p>
                    </div>
                  ))}
                </div>

                <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700">
                  <h5 class="font-semibold text-gray-900 dark:text-white mb-3 transition-colors">Funciones Avanzadas:</h5>
                  <div class="flex flex-wrap gap-2">
                    {funcionesExcel.map((func) => (
                      <span class="px-3 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-full text-sm transition-colors">
                        {func}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </AnimatedCard>

          <!-- Módulo 3 -->
          <AnimatedCard delay={200}>
            <div>
              <div class="bg-[#6a040f] px-6 py-4 flex justify-between items-center">
                <h4 class="text-white font-bold text-lg">Módulo 3: Normas APA 7ma Edición</h4>
                <span class="text-white/80 text-sm">4 sesiones de 2 horas</span>
              </div>
              <div class="p-6">
                <div class="grid md:grid-cols-2 gap-6">
                  {modulosAPA.map((mod, index) => (
                    <div 
                      class="flex items-start gap-4 group"
                      data-aos="fade-right"
                      data-aos-delay={index * 100}
                    >
                      <div class="w-10 h-10 bg-[#ffba08] rounded-lg flex items-center justify-center flex-shrink-0 shadow-md group-hover:scale-110 transition-transform">
                        <span class="text-[#6a040f] font-bold">{mod.num}</span>
                      </div>
                      <div>
                        <h5 class="font-semibold text-gray-900 dark:text-white transition-colors">{mod.title}</h5>
                        <p class="text-sm text-gray-600 dark:text-gray-300 transition-colors">{mod.desc}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </AnimatedCard>

          <!-- Módulo 4 -->
          <AnimatedCard delay={300}>
            <div>
              <div class="bg-[#6a040f] px-6 py-4">
                <h4 class="text-white font-bold text-lg">Módulo 4: Metodología de Investigación</h4>
              </div>
              <div class="p-6">
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <h5 class="font-semibold text-gray-900 dark:text-white mb-3 transition-colors">Diseño de Investigación:</h5>
                    <ul class="text-gray-600 dark:text-gray-300 space-y-2 transition-colors">
                      <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-[#6a040f] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Formulación de problemas
                      </li>
                      <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-[#6a040f] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Definición de objetivos
                      </li>
                      <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-[#6a040f] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Marco teórico y antecedentes
                      </li>
                    </ul>
                  </div>
                  
                  <div>
                    <h5 class="font-semibold text-gray-900 dark:text-white mb-3 transition-colors">Análisis de Datos:</h5>
                    <ul class="text-gray-600 dark:text-gray-300 space-y-2 transition-colors">
                      <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-[#6a040f] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Estadística descriptiva
                      </li>
                      <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-[#6a040f] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Análisis de tendencias
                      </li>
                      <li class="flex items-start gap-2">
                        <svg class="w-5 h-5 text-[#6a040f] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Conclusiones y recomendaciones
                      </li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          </AnimatedCard>
        </div>

        <!-- Video Tutorial -->
        <div class="mt-12 bg-gradient-to-r from-[#6a040f] to-[#370617] rounded-2xl p-8 text-center relative overflow-hidden" data-aos="zoom-in">
          <!-- Animated background -->
          <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-10 left-10 w-32 h-32 bg-[#ffba08]/10 rounded-full blur-2xl animate-pulse"></div>
            <div class="absolute bottom-10 right-10 w-48 h-48 bg-[#9f0606]/20 rounded-full blur-2xl animate-pulse" style="animation-delay: 0.5s;"></div>
          </div>
          
          <div class="relative z-10">
            <div class="w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-4 animate-pulse">
              <svg class="w-8 h-8 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            
            <h3 class="text-2xl font-display font-bold text-white mb-2">Video Tutorial Próximamente</h3>
            <p class="text-white/80 mb-4">
              "Cómo Buscar y Limpiar Bases de Datos Económicas" - Tutorial completo paso a paso
            </p>
            
            <div class="inline-flex items-center gap-2 bg-white/20 px-4 py-2 rounded-full text-white text-sm hover:bg-white/30 transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
              </svg>
              Publicado en YouTube - Próximamente
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gray-50 dark:bg-gray-800 transition-colors duration-300 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-96 h-96 bg-[#6a040f]/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#ffba08]/5 rounded-full blur-3xl"></div>
    </div>
    
    <div class="container mx-auto px-6 text-center relative z-10">
      <div data-aos="fade-up">
        <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-4">
          ¿Necesitas capacitar a tu equipo?
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto transition-colors">
          Puedo adaptar este programa de formación para las necesidades específicas de tu institución o proyecto de investigación.
        </p>
        <a 
          href={`${baseUrl}contacto`}
          class="inline-flex items-center gap-2 bg-[#6a040f] text-white px-8 py-4 rounded-full font-semibold hover:bg-[#370617] hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          Solicitar Información
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Signature Footer -->
  <section class="py-12 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <SignatureFooter />
    </div>
  </section>

</Layout>

<style>
  .org-tag {
    transition: all 0.3s ease;
  }
  
  .org-tag:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(106, 4, 15, 0.2);
  }
</style>
