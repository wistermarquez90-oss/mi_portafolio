---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL || '/';
---

<Layout title="404 - Página No Encontrada | Wister Márquez">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="text-center px-6" data-aos="zoom-in">
      <!-- 404 Large -->
      <div class="relative mb-8">
        <h1 class="text-9xl md:text-[12rem] font-display font-bold text-white/10 select-none">404</h1>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-6xl md:text-8xl font-display font-bold text-[#ffba08]">404</span>
        </div>
      </div>
      
      <!-- Message -->
      <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-4" data-aos="fade-up" data-aos-delay="200">
        Página No Encontrada
      </h2>
      
      <p class="text-xl text-white/80 mb-8 max-w-md mx-auto" data-aos="fade-up" data-aos-delay="300">
        Lo sentimos, la página que buscas no existe o ha sido movida.
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-aos="fade-up" data-aos-delay="400">
        <a 
          href={baseUrl}
          class="inline-flex items-center justify-center gap-2 bg-[#ffba08] text-[#6a040f] px-8 py-4 rounded-full font-semibold hover:bg-white transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Volver al Inicio
        </a>
        
        <a 
          href={`${baseUrl}contacto`}
          class="inline-flex items-center justify-center gap-2 border-2 border-white text-white px-8 py-4 rounded-full font-semibold hover:bg-white hover:text-[#6a040f] transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Contactar
        </a>
      </div>
      
      <!-- Decorative Elements -->
      <div class="mt-16 flex justify-center gap-2" data-aos="fade-up" data-aos-delay="500">
        <div class="w-3 h-3 rounded-full bg-[#ffba08] animate-bounce" style="animation-delay: 0s"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffba08] animate-bounce" style="animation-delay: 0.1s"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffba08] animate-bounce" style="animation-delay: 0.2s"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffba08] animate-bounce" style="animation-delay: 0.3s"></div>
        <div class="w-3 h-3 rounded-full bg-[#ffba08] animate-bounce" style="animation-delay: 0.4s"></div>
      </div>
    </div>
  </div>
</Layout>