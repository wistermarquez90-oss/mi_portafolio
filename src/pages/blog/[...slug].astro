---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import Skeleton from '../../components/Skeleton.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const baseUrl = import.meta.env.BASE_URL || '/';

// Get related posts (same category, different post)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug)
  .slice(0, 2);
---

<Layout 
  title={`${post.data.title} | Blog`} 
  description={post.data.description}>
  
  <!-- Hero -->
  <section class="pt-32 pb-20 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6 max-w-4xl" data-aos="fade-up">
      <!-- Category -->
      <div class="flex items-center gap-4 mb-6">
        <a 
          href={`${baseUrl}blog`}
          class="inline-flex items-center gap-2 text-white/80 hover:text-[#ffba08] transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Volver al Blog
        </a>
        <span class="px-3 py-1 bg-[#ffba08] text-[#6a040f] text-sm font-medium rounded-full">
          {post.data.category}
        </span>
      </div>
      
      <!-- Title -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold text-white mb-6 leading-tight">
        {post.data.title}
      </h1>
      
      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-6 text-white/80">
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 bg-[#ffba08] rounded-full flex items-center justify-center">
            <span class="text-[#6a040f] font-bold">W</span>
          </div>
          <div>
            <p class="font-medium text-white">{post.data.author}</p>
            <p class="text-sm">Economista & Data Analyst</p>
          </div>
        </div>
        
        <div class="flex items-center gap-4 text-sm">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {new Date(post.data.date).toLocaleDateString('es-ES', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </span>
          
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {post.data.readingTime} min de lectura
          </span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Article Content -->
  <article class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-6 max-w-4xl">
      <div 
        class="prose prose-lg max-w-none dark:prose-invert
          prose-headings:text-[#6a040f] dark:prose-headings:text-[#ffba08]
          prose-h1:text-3xl prose-h1:font-display prose-h1:font-bold
          prose-h2:text-2xl prose-h2:font-display prose-h2:font-bold prose-h2:border-b-2 prose-h2:border-[#ffba08] prose-h2:pb-2
          prose-h3:text-xl prose-h3:font-bold
          prose-a:text-[#6a040f] dark:prose-a:text-[#ffba08] prose-a:no-underline hover:prose-a:underline
          prose-strong:text-[#6a040f] dark:prose-strong:text-[#ffba08]
          prose-blockquote:border-l-4 prose-blockquote:border-[#ffba08] prose-blockquote:bg-[#6a040f]/5 prose-blockquote:pl-4 prose-blockquote:py-2 prose-blockquote:rounded-r-lg
          prose-code:text-[#6a040f] dark:prose-code:text-[#ffba08] prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:px-1 prose-code:rounded
          prose-pre:bg-gray-900 prose-pre:text-white
          prose-table:overflow-hidden prose-table:rounded-lg prose-table:shadow-lg
          prose-th:bg-gradient-to-r prose-th:from-[#6a040f] prose-th:to-[#9f0606] prose-th:text-white prose-th:font-semibold prose-th:px-4 prose-th:py-3
          prose-td:px-4 prose-td:py-3 prose-td:border-b prose-td:border-gray-200 dark:prose-td:border-gray-700
          prose-tr:hover:prose-tr:bg-gray-50 dark:prose-tr:hover:bg-gray-800
          prose-li:marker:text-[#6a040f] dark:prose-li:marker:text-[#ffba08]"
        data-aos="fade-up"
      >
        <Content />
      </div>
      
      <!-- Share Section -->
      <div class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-700" data-aos="fade-up">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Compartir artículo</h3>
        <div class="flex gap-3">
          <a 
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://wistermarquez90-oss.github.io${baseUrl}blog/${post.slug}`)}`}
            target="_blank"
            class="w-10 h-10 bg-[#1DA1F2] text-white rounded-full flex items-center justify-center hover:opacity-80 transition-opacity"
            aria-label="Compartir en Twitter"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          
          <a 
            href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`https://wistermarquez90-oss.github.io${baseUrl}blog/${post.slug}`)}&title=${encodeURIComponent(post.data.title)}`}
            target="_blank"
            class="w-10 h-10 bg-[#0A66C2] text-white rounded-full flex items-center justify-center hover:opacity-80 transition-opacity"
            aria-label="Compartir en LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          
          <button 
            onclick="navigator.clipboard.writeText(window.location.href); alert('Enlace copiado al portapapeles')"
            class="w-10 h-10 bg-gray-600 text-white rounded-full flex items-center justify-center hover:opacity-80 transition-opacity"
            aria-label="Copiar enlace"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </article>
  
  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="py-16 bg-gray-50 dark:bg-gray-800">
      <div class="container mx-auto px-6 max-w-4xl">
        <h2 class="text-2xl font-display font-bold text-[#6a040f] dark:text-white mb-8" data-aos="fade-up">
          Artículos relacionados
        </h2>
        
        <div class="grid md:grid-cols-2 gap-6">
          {relatedPosts.map((relatedPost, index) => (
            <article 
              class="bg-white dark:bg-gray-700 rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
              data-aos="fade-up"
              data-aos-delay={index * 100}
            >
              <div class="p-6">
                <span class="text-sm text-[#6a040f] dark:text-[#ffba08] font-medium">{relatedPost.data.category}</span>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-2 mb-3 hover:text-[#6a040f] dark:hover:text-[#ffba08] transition-colors">
                  <a href={`${baseUrl}blog/${relatedPost.slug}`}>{relatedPost.data.title}</a>
                </h3>
                <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-2">{relatedPost.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
  
  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6 text-center" data-aos="fade-up">
      <h2 class="text-3xl font-display font-bold text-white mb-4">
        ¿Te interesa colaborar?
      </h2>
      
      <p class="text-white/80 mb-8 max-w-2xl mx-auto">
        Estoy abierto a proyectos de investigación, consultoría en e-commerce y análisis de datos.
      </p>
      
      <a 
        href={`${baseUrl}contacto`}
        class="inline-flex items-center gap-2 bg-[#ffba08] text-[#6a040f] px-8 py-4 rounded-full font-semibold hover:bg-white transition-colors"
      >
        Contactar Ahora
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>