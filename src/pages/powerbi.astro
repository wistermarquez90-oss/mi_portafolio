---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import AnimatedCard from '../components/AnimatedCard.astro';
import SignatureFooter from '../components/SignatureFooter.astro';

const dashboards = [
  {
    title: "Plataformas Digitales",
    description: "Monitorización de KPIs, ventas y publicidad digital (ACOS) en múltiples marketplaces.",
    embedUrl: "https://app.powerbi.com/view?r=eyJrIjoiODM0YWE2YzktMmE5Ni00NjIxLWE3ZTItNjQ5MTAyZTFkOGY3IiwidCI6IjNjMjg3MGY4LWZjODgtNGQ5My1hYjUwLWZkZWI0NmZlY2FkZiJ9",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
    delay: 0
  },
  {
    title: "Dashboard Macroeconómico",
    description: "Comparativa de indicadores globales y tendencias económicas internacionales.",
    embedUrl: "https://app.powerbi.com/view?r=eyJrIjoiNTMyYWE0YTEtYThlMi00ZWUzLTg1ZDUtYzg0ODA5MDUzMDgzIiwidCI6IjNjMjg3MGY4LWZjODgtNGQ5My1hYjUwLWZkZWI0NmZlY2FkZiJ9",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    delay: 100
  },
  {
    title: "Análisis de Finanzas",
    description: "Estudio de rentabilidad y proyecciones financieras con análisis de escenarios.",
    embedUrl: null,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`,
    delay: 200,
    comingSoon: true
  },
  {
    title: "Presupuesto y Gastos",
    description: "Control de ejecución presupuestaria con seguimiento de indicadores.",
    embedUrl: null,
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    delay: 300,
    comingSoon: true
  }
];

const skills = ['Power BI', 'DAX', 'Power Query', 'SQL', 'Excel Avanzado', 'Python (Pandas)', 'Data Visualization'];
---

<Layout title="Dashboards Power BI | Wister Márquez">
  
  <PageHeader
    badge="Visualización de Datos"
    title="Portafolio Power BI"
    description="Dashboards interactivos de análisis comercial, indicadores macroeconómicos y gestión financiera"
  />

  <section class="py-20 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-8">
        {dashboards.map((dashboard) => (
          <AnimatedCard delay={dashboard.delay} class="h-full">
            <div class="h-full flex flex-col">
              <div class="bg-[#6a040f] px-6 py-4 flex items-center gap-3">
                <div class="text-[#ffba08]" set:html={dashboard.icon} />
                <h3 class="text-white font-semibold">{dashboard.title}</h3>
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <p class="text-gray-600 dark:text-gray-300 mb-4 transition-colors duration-300">
                  {dashboard.description}
                </p>
                
                {dashboard.comingSoon ? (
                  <div class="aspect-video bg-gray-100 dark:bg-gray-700 rounded-lg flex items-center justify-center">
                    <div class="text-center">
                      <div class="inline-flex items-center justify-center w-16 h-16 bg-[#6a040f]/10 rounded-full mb-4">
                        <svg class="w-8 h-8 text-[#6a040f] animate-spin" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </div>
                      <p class="text-gray-500 dark:text-gray-400 font-medium">Dashboard en desarrollo</p>
                    </div>
                  </div>
                ) : (
                  <div class="aspect-video bg-gray-100 dark:bg-gray-900 rounded-lg overflow-hidden">
                    <iframe 
                      title={dashboard.title}
                      width="100%"
                      height="100%"
                      src={dashboard.embedUrl}
                      frameborder="0"
                      allowFullScreen="true"
                      class="w-full h-full"
                    ></iframe>
                  </div>
                )}
              </div>
            </div>
          </AnimatedCard>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="py-20 bg-gray-50 dark:bg-gray-800 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-3xl font-display font-bold text-[#6a040f] dark:text-[#ffba08] mb-4">
          Herramientas de Análisis
        </h2>
        <p class="text-gray-600 dark:text-gray-300 transition-colors duration-300">
          Tecnologías utilizadas en la creación de estos dashboards
        </p>
      </div>
      
      <div class="flex flex-wrap justify-center gap-4" data-aos="fade-up">
        {skills.map((skill, index) => (
          <span 
            class="skill-tag px-6 py-3 bg-white dark:bg-gray-700 rounded-full shadow-md text-[#6a040f] dark:text-[#ffba08] font-medium border border-gray-100 dark:border-gray-600 hover:shadow-lg hover:scale-105 transition-all duration-300 cursor-default"
            style={`animation-delay: ${index * 100}ms`}
          >
            {skill}
          </span>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Signature Footer -->
  <section class="py-12 bg-white dark:bg-gray-900 transition-colors duration-300">
    <div class="container mx-auto px-6">
      <SignatureFooter />
    </div>
  </section>

</Layout>

<style>
  .skill-tag {
    animation: skillFloat 3s ease-in-out infinite;
  }
  
  .skill-tag:nth-child(2n) {
    animation-delay: 0.5s;
  }
  
  .skill-tag:nth-child(3n) {
    animation-delay: 1s;
  }
  
  @keyframes skillFloat {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }
</style>
