---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboards Power BI | Wister Márquez">
  <section class="pt-32 pb-20 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6">
      <div class="text-center" data-aos="fade-up">
        <p class="text-[#ffba08] font-semibold tracking-wider uppercase mb-4">Visualización de Datos</p>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">
          Portafolio Power BI
        </h1>
        <p class="text-xl text-white/80 max-w-3xl mx-auto">
          Dashboards interactivos de análisis comercial, indicadores macroeconómicos y gestión financiera
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-8">
        <!-- Dashboard 1 -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100" data-aos="fade-up">
          <div class="bg-[#6a040f] px-6 py-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            <h3 class="text-white font-semibold">1. Plataformas Digitales</h3>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4">Monitorización de KPIs, ventas y publicidad digital (ACOS) en múltiples marketplaces.</p>
            <div class="aspect-video bg-gray-100 rounded-lg overflow-hidden">
              <iframe 
                title="Plataformas Digitales" 
                width="100%" 
                height="100%" 
                src="https://app.powerbi.com/view?r=eyJrIjoiODM0YWE2YzktMmE5Ni00NjIxLWE3ZTItNjQ5MTAyZTFkOGY3IiwidCI6IjNjMjg3MGY4LWZjODgtNGQ5My1hYjUwLWZkZWI0NmZlY2FkZiJ9" 
                frameborder="0" 
                allowFullScreen="true">
              </iframe>
            </div>
          </div>
        </div>

        <!-- Dashboard 2 -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100" data-aos="fade-up" data-aos-delay="100">
          <div class="bg-[#6a040f] px-6 py-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="text-white font-semibold">2. Dashboard Macroeconómico</h3>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4">Comparativa de indicadores globales y tendencias económicas internacionales.</p>
            <div class="aspect-video bg-gray-100 rounded-lg overflow-hidden">
              <iframe 
                title="Dashboard Macro" 
                width="100%" 
                height="100%" 
                src="https://app.powerbi.com/view?r=eyJrIjoiNTMyYWE0YTEtYThlMi00ZWUzLTg1ZDUtYzg0ODA5MDUzMDgzIiwidCI6IjNjMjg3MGY4LWZjODgtNGQ5My1hYjUwLWZkZWI0NmZlY2FkZiJ9" 
                frameborder="0" 
                allowFullScreen="true">
              </iframe>
            </div>
          </div>
        </div>

        <!-- Dashboard 3 -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100" data-aos="fade-up" data-aos-delay="200">
          <div class="bg-[#6a040f] px-6 py-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            <h3 class="text-white font-semibold">3. Análisis de Finanzas</h3>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4">Estudio de rentabilidad y proyecciones financieras con análisis de escenarios.</p>
            <div class="aspect-video bg-gray-200 rounded-lg flex items-center justify-center">
              <p class="text-gray-500 font-medium">Dashboard en desarrollo</p>
            </div>
          </div>
        </div>

        <!-- Dashboard 4 -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100" data-aos="fade-up" data-aos-delay="300">
          <div class="bg-[#6a040f] px-6 py-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#ffba08]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="text-white font-semibold">4. Presupuesto y Gastos</h3>
          </div>
          <div class="p-6">
            <p class="text-gray-600 mb-4">Control de ejecución presupuestaria con seguimiento de indicadores.</p>
            <div class="aspect-video bg-gray-200 rounded-lg flex items-center justify-center">
              <p class="text-gray-500 font-medium">Dashboard en desarrollo</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="text-center mb-12" data-aos="fade-up">
        <h2 class="text-3xl font-display font-bold text-[#6a040f] mb-4">Herramientas de Análisis</h2>
        <p class="text-gray-600">Tecnologías utilizadas en la creación de estos dashboards</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4" data-aos="fade-up">
        {['Power BI', 'DAX', 'Power Query', 'SQL', 'Excel Avanzado', 'Python (Pandas)', 'Data Visualization'].map((skill) => (
          <span class="px-6 py-3 bg-white rounded-full shadow-md text-[#6a040f] font-medium border border-gray-100 hover:shadow-lg transition-shadow">
            {skill}
          </span>
        ))}
      </div>
    </div>
  </section>
</Layout>
