---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const pasantiasEntries = await getCollection('pasantias');
---

<Layout title="Pasantías en Investigación | Wister Márquez">
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 bg-gradient-to-br from-[#6a040f] to-[#370617]">
    <div class="container mx-auto px-6">
      <div class="text-center" data-aos="fade-up">
        <p class="text-[#ffba08] font-semibold tracking-wider uppercase mb-4">Experiencia Profesional</p>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">
          Pasantías en Investigación
        </h1>
        <p class="text-xl text-white/80 max-w-3xl mx-auto">
          Coordinación de proyectos de investigación económica y desarrollo de sistemas de estandarización académica
        </p>
      </div>
    </div>
  </section>

  <!-- Proyecto VENCOLECO -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <div class="bg-[#6a040f]/5 border-l-4 border-[#6a040f] p-8 rounded-r-xl mb-12" data-aos="fade-up">
          <h2 class="text-2xl font-display font-bold text-[#6a040f] mb-4">Proyecto VENCOLECO</h2>
          <p class="text-lg text-gray-700 mb-4">
            <strong>Venezuela-Colombia Economic Dynamics</strong> — Investigación sobre la dinámica de la economía internacional entre Venezuela y Colombia (2013-2025).
          </p>
          <div class="grid md:grid-cols-3 gap-4 text-center">
            <div class="bg-white p-4 rounded-lg shadow-sm">
              <div class="text-3xl font-bold text-[#6a040f]">13</div>
              <p class="text-sm text-gray-600">Estudiantes</p>
            </div>
            <div class="bg-white p-4 rounded-lg shadow-sm">
              <div class="text-3xl font-bold text-[#6a040f]">13</div>
              <p class="text-sm text-gray-600">Años de Análisis</p>
            </div>
            <div class="bg-white p-4 rounded-lg shadow-sm">
              <div class="text-3xl font-bold text-[#6a040f]">3</div>
              <p class="text-sm text-gray-600">Dimensiones</p>
            </div>
          </div>
        </div>

        <!-- Dimensiones de Investigación -->
        <h3 class="text-2xl font-display font-bold text-[#6a040f] mb-8" data-aos="fade-up">Dimensiones del Proyecto</h3>
        
        <div class="grid md:grid-cols-3 gap-6 mb-12">
          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow" data-aos="fade-up">
            <div class="w-12 h-12 bg-[#6a040f] rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 mb-2">Balanza Comercial</h4>
            <ul class="text-gray-600 text-sm space-y-1">
              <li>• Importaciones/exportaciones</li>
              <li>• Análisis sectorial CIIU/HS</li>
              <li>• Evolución mensual/trimestral</li>
              <li>• Diversificación de productos</li>
            </ul>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow" data-aos="fade-up" data-aos-delay="100">
            <div class="w-12 h-12 bg-[#6a040f] rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 mb-2">Flujos Migratorios</h4>
            <ul class="text-gray-600 text-sm space-y-1">
              <li>• Estadísticas entradas/salidas</li>
              <li>• Caracterización poblacional</li>
              <li>• Políticas migratorias</li>
              <li>• Impacto laboral</li>
            </ul>
          </div>

          <div class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow" data-aos="fade-up" data-aos-delay="200">
            <div class="w-12 h-12 bg-[#6a040f] rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
              </svg>
            </div>
            <h4 class="font-bold text-gray-900 mb-2">Marco Normativo</h4>
            <ul class="text-gray-600 text-sm space-y-1">
              <li>• Acuerdos comerciales</li>
              <li>• Decretos presidenciales</li>
              <li>• Tratados de inversión</li>
              <li>• Decisiones CAN/ALADI</li>
            </ul>
          </div>
        </div>

        <!-- Documentos Markdown -->
        <h3 class="text-2xl font-display font-bold text-[#6a040f] mb-8" data-aos="fade-up">Documentación del Proyecto</h3>

        <div class="space-y-6">
          {pasantiasEntries.map((entry, index) => (
            <div 
              class="bg-white border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-all cursor-pointer group"
              data-aos="fade-up"
              data-aos-delay={index * 100}
            >
              <a href={`/pasantias/${entry.slug}`} class="block">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <h4 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-[#6a040f] transition-colors">
                      {entry.data.title}
                    </h4>
                    <p class="text-gray-600 mb-4">{entry.data.description}</p>
                    
                    <div class="flex items-center gap-4 text-sm text-gray-500">
                      <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        {entry.data.date}
                      </span>
                      <span class="flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                        {entry.data.readingTime}
                      </span>
                    </div>
                  </div>
                  
                  <svg class="w-6 h-6 text-gray-400 group-hover:text-[#6a040f] transition-colors ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </a>
            </div>
          ))}
        </div>

        <!-- Hitos Fronterizos -->
        <h3 class="text-2xl font-display font-bold text-[#6a040f] mt-12 mb-8" data-aos="fade-up">Hitos Documentados</h3>

        <div class="relative" data-aos="fade-up">
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-[#6a040f]/20"></div>
          
          {[
            { date: '19 ago 2015', title: 'Cierre de frontera', desc: 'Estado de excepción en Táchira - Colapso comercial formal' },
            { date: '23 feb 2019', title: 'Ruptura diplomática total', desc: 'Reconocimiento Guaidó - Cierre de embajadas' },
            { date: '7 ago 2022', title: 'Reapertura oficial', desc: 'Gobierno Petro - Recuperación gradual de relaciones' },
            { date: '26 sep 2022', title: 'Apertura comercial total', desc: 'Normalización del comercio bilateral' }
          ].map((hito, index) => (
            <div class="relative flex items-start mb-8 last:mb-0">
              <div class="absolute left-2 w-4 h-4 bg-[#6a040f] rounded-full border-4 border-white shadow"></div>
              <div class="ml-12">
                <span class="text-sm font-semibold text-[#6a040f]">{hito.date}</span>
                <h4 class="font-bold text-gray-900 mt-1">{hito.title}</h4>
                <p class="text-gray-600 text-sm">{hito.desc}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- Sistema de Calidad -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <h3 class="text-2xl font-display font-bold text-[#6a040f] mb-8 text-center" data-aos="fade-up">Sistema de Control de Calidad</h3>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-xl shadow-sm" data-aos="fade-up">
            <h4 class="font-bold text-gray-900 mb-4">Estructura de Supervisión</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• <strong>4 grupos</strong> según complejidad</li>
              <li>• <strong>Revisiones semanales</strong> individuales</li>
              <li>• <strong>Revisiones quincenales</strong> grupales</li>
              <li>• <strong>Matriz de evaluación</strong> de 100 puntos</li>
            </ul>
          </div>

          <div class="bg-white p-6 rounded-xl shadow-sm" data-aos="fade-up" data-aos-delay="100">
            <h4 class="font-bold text-gray-900 mb-4">Escala de Calificación</h4>
            <div class="space-y-2">
              <div class="flex justify-between items-center p-2 bg-green-50 rounded">
                <span class="text-sm">88-100 Excelente</span>
                <span class="text-xs text-green-700">Sin correcciones</span>
              </div>
              <div class="flex justify-between items-center p-2 bg-blue-50 rounded">
                <span class="text-sm">68-88 Bueno</span>
                <span class="text-xs text-blue-700">Correcciones menores</span>
              </div>
              <div class="flex justify-between items-center p-2 bg-yellow-50 rounded">
                <span class="text-sm">60-67 Aceptable</span>
                <span class="text-xs text-yellow-700">Correcciones moderadas</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
