---
const skillCategories = [
  {
    title: 'Business Intelligence',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
    skills: [
      { name: 'Power BI', level: 90, certified: true },
      { name: 'Excel Avanzado', level: 85, certified: false },
      { name: 'DAX', level: 80, certified: false },
    ]
  },
  {
    title: 'Programación',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>',
    skills: [
      { name: 'Python', level: 65, certified: false },
      { name: 'Lenguaje R', level: 60, certified: false },
      { name: 'SQL', level: 70, certified: false },
    ]
  },
  {
    title: 'E-commerce',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>',
    skills: [
      { name: 'Mercado Libre Ads', level: 90, certified: false },
      { name: 'Amazon Seller', level: 75, certified: false },
      { name: 'Shopify', level: 70, certified: false },
      { name: 'Aliexpress', level: 65, certified: false },
    ]
  },
  {
    title: 'ERP & Sistemas',
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>',
    skills: [
      { name: 'Odoo', level: 70, certified: false },
      { name: 'Bsale', level: 85, certified: false },
    ]
  }
];

const tools = [
  'Power BI Desktop', 'Power Query', 'DAX Studio', 'Excel (Macros, VBA)',
  'Google Analytics', 'Google Ads', 'Meta Ads', 'Jupyter Notebook',
  'RStudio', 'MySQL Workbench', 'VS Code', 'Git'
];
---

<section id="habilidades" class="py-20 lg:py-32 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-block mb-4 px-4 py-1 bg-wine/10 rounded-full" data-aos="fade-up">
        <span class="text-wine font-medium text-sm">Habilidades</span>
      </div>
      
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-6" data-aos="fade-up" data-aos-delay="100">
        Stack Tecnológico <span class="text-wine">& Expertise</span>
      </h2>
      
      <p class="text-gray-600 text-lg" data-aos="fade-up" data-aos-delay="200">
        Herramientas y tecnologías que utilizo para transformar datos en insights de negocio
      </p>
    </div>
    
    <!-- Skills Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {skillCategories.map((category, index) => (
        <div 
          class="bg-white rounded-2xl p-6 lg:p-8 shadow-sm hover:shadow-lg transition-shadow duration-300"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="flex items-center space-x-3 mb-6">
            <div class="w-12 h-12 bg-wine/10 rounded-lg flex items-center justify-center">
              <div class="text-wine">
                <Fragment set:html={category.icon} />
              </div>
            </div>
            <h3 class="font-display font-bold text-xl text-gray-900">{category.title}</h3>
          </div>
          
          <div class="space-y-4">
            {category.skills.map((skill) => (
              <div>
                <div class="flex justify-between items-center mb-2">
                  <div class="flex items-center space-x-2">
                    <span class="font-medium text-gray-700">{skill.name}</span>
                    {skill.certified && (
                      <span class="px-2 py-0.5 bg-gold/20 text-gold-700 text-xs font-medium rounded-full">
                        Certificado
                      </span>
                    )}
                  </div>
                  <span class="text-sm text-gray-500">{skill.level}%</span>
                </div>
                
                <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                  <div 
                    class="h-full bg-gradient-to-r from-wine to-gold rounded-full transition-all duration-1000 ease-out"
                    style={`width: 0%`}
                    data-skill-level={skill.level}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    <!-- Tools Cloud -->
    <div class="mt-16 bg-wine rounded-2xl p-8 lg:p-12" data-aos="fade-up">
      <div class="text-center mb-8">
        <h3 class="font-display text-2xl font-bold text-white mb-2">Herramientas que utilizo</h3>
        <p class="text-wine-200">Software y plataformas de mi día a día</p>
      </div>
      
      <div class="flex flex-wrap justify-center gap-3">
        {tools.map((tool, index) => (
          <span 
            class="px-4 py-2 bg-white/10 text-white rounded-full text-sm font-medium hover:bg-gold hover:text-wine transition-all duration-300 cursor-default"
            data-aos="zoom-in"
            data-aos-delay={index * 50}
          >
            {tool}
          </span>
        ))}
      </div>
    </div>
  </div>
  
  <script>
    // Animate skill bars when they come into view
    const observerCallback = (entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const bar = entry.target;
          const level = bar.getAttribute('data-skill-level');
          bar.style.width = level + '%';
          observer.unobserve(bar);
        }
      });
    };
    
    const observer = new IntersectionObserver(observerCallback, {
      threshold: 0.5
    });
    
    document.querySelectorAll('[data-skill-level]').forEach(bar => {
      observer.observe(bar);
    });
  </script>
</section>
