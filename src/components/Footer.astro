---
const baseUrl = import.meta.env.BASE_URL || '/';
const currentYear = new Date().getFullYear();

const socialLinks = [
  { 
    href: 'https://linkedin.com/in/wister-marquez-duque', 
    label: 'LinkedIn',
    icon: '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>'
  },
  { 
    href: 'mailto:wistermarquez90@gmail.com', 
    label: 'Email',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>'
  },
  { 
    href: 'tel:+584145716776', 
    label: 'Teléfono',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>'
  },
];

const footerLinks = [
  { href: `${baseUrl}#sobre-mi`, label: 'Sobre Mí' },
  { href: `${baseUrl}#experiencia`, label: 'Experiencia' },
  { href: `${baseUrl}powerbi`, label: 'Power BI' },
  { href: `${baseUrl}investigacion`, label: 'Investigación' },
  { href: `${baseUrl}contacto`, label: 'Contacto' },
];
---

<footer class="bg-wine text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main Footer Content -->
    <div class="py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center space-x-3">
          <div class="w-12 h-12 bg-gold rounded-lg flex items-center justify-center">
            <span class="text-wine font-display font-bold text-xl">W</span>
          </div>
          <div>
            <h3 class="font-display font-bold text-xl">Wister Márquez</h3>
            <p class="text-wine-200 text-sm">Economista en Formación</p>
          </div>
        </div>
        <p class="text-wine-100 text-sm leading-relaxed">
          Especialista en E-commerce y Análisis de Datos. Transformando datos en decisiones estratégicas para el crecimiento empresarial.
        </p>
        
        <!-- Social Links -->
        <div class="flex space-x-4 pt-2">
          {socialLinks.map((link) => (
            <a 
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-wine-200 hover:text-gold transition-colors duration-200"
              aria-label={link.label}
            >
              <Fragment set:html={link.icon} />
            </a>
          ))}
        </div>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h4 class="font-display font-semibold text-lg mb-4">Enlaces Rápidos</h4>
        <ul class="space-y-2">
          {footerLinks.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-wine-200 hover:text-gold transition-colors duration-200 text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Contact Info -->
      <div>
        <h4 class="font-display font-semibold text-lg mb-4">Contacto</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-wine-100">Mérida, Venezuela</span>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:wistermarquez90@gmail.com" class="text-wine-100 hover:text-gold transition-colors">
              wistermarquez90@gmail.com
            </a>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-gold flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+584145716776" class="text-wine-100 hover:text-gold transition-colors">
              +58 414-5716776
            </a>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom Bar -->
    <div class="border-t border-wine-800 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-wine-200 text-sm">
          &copy; {currentYear} Wister Márquez. Todos los derechos reservados.
        </p>
        
        <p class="text-wine-300 text-xs">
          Diseñado con <span class="text-gold">❤</span> usando Astro & Tailwind CSS
        </p>
      </div>
    </div>
  </div>
</footer>
