---
const baseUrl = import.meta.env.BASE_URL || '/';
---

<section class="py-20 lg:py-32 bg-wine relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,186,8,0.5) 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>
  
  <!-- Decorative Elements -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-gold/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-gold/5 rounded-full blur-3xl"></div>
  
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div data-aos="fade-up">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        ¿Listo para transformar tus datos en
        <span class="text-gold">resultados?</span>
      </h2>
      
      <p class="text-wine-100 text-lg mb-10 max-w-2xl mx-auto">
        Estoy disponible para proyectos de consultoría en e-commerce, análisis de datos 
        y desarrollo de dashboards personalizados. ¡Hablemos de tu próximo proyecto!
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href={`${baseUrl}contacto`}
          class="inline-flex items-center justify-center px-8 py-4 bg-gold text-wine font-bold rounded-lg hover:bg-gold-300 transition-all duration-300 hover:shadow-lg hover:shadow-gold/20 group"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          Contactar Ahora
        </a>
        
        <a 
          href={`${baseUrl}powerbi`}
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-gold text-gold font-semibold rounded-lg hover:bg-gold hover:text-wine transition-all duration-300"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
          Ver Dashboards
        </a>
      </div>
    </div>
  </div>
</section>
