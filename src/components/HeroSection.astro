---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Elements -->
  <div class="absolute inset-0 bg-gradient-to-br from-wine via-wine to-wine-900"></div>
  
  <!-- Decorative Grid Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,186,8,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,186,8,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
  </div>
  
  <!-- Animated Circles -->
  <div class="absolute top-20 left-10 w-64 h-64 bg-gold/10 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-gold/5 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      
      <!-- Text Content -->
      <div class="text-center lg:text-left" data-aos="fade-right">
        <div class="inline-block mb-4 px-4 py-2 bg-gold/20 rounded-full border border-gold/30">
          <span class="text-gold font-medium text-sm tracking-wide">
            Economista en Formación | Especialista en E-commerce
          </span>
        </div>
        
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-white mb-6 leading-tight">
          Wister
          <span class="text-gold">Márquez</span>
        </h1>
        
        <p class="text-wine-100 text-lg sm:text-xl mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Transformando datos en decisiones estratégicas. Especializado en análisis financiero, 
          control de ACOS en marketplaces y business intelligence con Power BI.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-8">
          <a 
            href="/proyectos-powerbi" 
            class="inline-flex items-center justify-center px-8 py-4 bg-gold text-wine font-semibold rounded-lg hover:bg-gold-300 transition-all duration-300 hover:shadow-lg hover:shadow-gold/20 group"
          >
            Ver Dashboards
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </a>
          
          <a 
            href="/contacto" 
            class="inline-flex items-center justify-center px-8 py-4 border-2 border-gold text-gold font-semibold rounded-lg hover:bg-gold hover:text-wine transition-all duration-300"
          >
            Contactar
          </a>
        </div>
        
        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 text-center">
          <div data-aos="fade-up" data-aos-delay="100">
            <div class="text-3xl sm:text-4xl font-display font-bold text-gold">3+</div>
            <div class="text-wine-200 text-sm">Años Exp.</div>
          </div>
          <div data-aos="fade-up" data-aos-delay="200">
            <div class="text-3xl sm:text-4xl font-display font-bold text-gold">4</div>
            <div class="text-wine-200 text-sm">Dashboards</div>
          </div>
          <div data-aos="fade-up" data-aos-delay="300">
            <div class="text-3xl sm:text-4xl font-display font-bold text-gold">10+</div>
            <div class="text-wine-200 text-sm">Habilidades</div>
          </div>
        </div>
      </div>
      
      <!-- Visual Element -->
      <div class="hidden lg:flex justify-center" data-aos="fade-left">
        <div class="relative">
          <!-- Profile Card -->
          <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-8 border border-white/20 shadow-2xl">
            <div class="w-48 h-48 mx-auto mb-6 bg-gradient-to-br from-gold to-gold-400 rounded-full flex items-center justify-center shadow-lg">
              <span class="font-display text-6xl font-bold text-wine">W</span>
            </div>
            
            <div class="text-center space-y-2">
              <p class="text-gold font-medium">Digital Trade Manager</p>
              <p class="text-wine-200 text-sm">Morekashop · México</p>
              <div class="pt-4 flex justify-center space-x-3">
                <span class="px-3 py-1 bg-gold/20 text-gold text-xs rounded-full">Power BI</span>
                <span class="px-3 py-1 bg-gold/20 text-gold text-xs rounded-full">E-commerce</span>
                <span class="px-3 py-1 bg-gold/20 text-gold text-xs rounded-full">Mercado Libre</span>
              </div>
            </div>
          </div>
          
          <!-- Floating Badge -->
          <div class="absolute -top-4 -right-4 bg-gold text-wine px-4 py-2 rounded-lg font-semibold text-sm shadow-lg" data-aos="zoom-in" data-aos-delay="500">
            Disponible
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2" data-aos="fade-up" data-aos-delay="600">
    <a href="#sobre-mi" class="flex flex-col items-center text-wine-200 hover:text-gold transition-colors">
      <span class="text-xs mb-2">Descubre más</span>
      <svg class="w-6 h-6 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
