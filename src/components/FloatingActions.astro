---
// Floating Action Buttons - Quick actions that float on page
const baseUrl = import.meta.env.BASE_URL || '/';
---

<div class="floating-actions fixed bottom-24 right-6 z-40 flex flex-col gap-3">
  <!-- Contact Button -->
  <a 
    href={`${baseUrl}contacto`}
    class="floating-btn group w-12 h-12 bg-[#6a040f] hover:bg-[#ffba08] rounded-full shadow-lg flex items-center justify-center transition-all duration-300 hover:scale-110"
    aria-label="Contactar"
    data-aos="fade-left"
    data-aos-delay="100"
  >
    <svg class="w-5 h-5 text-white group-hover:text-[#6a040f] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>
    <span class="absolute right-14 bg-gray-900 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
      Contactar
    </span>
  </a>
  
  <!-- LinkedIn Button -->
  <a 
    href="https://linkedin.com/in/wister-marquez-duque"
    target="_blank"
    rel="noopener noreferrer"
    class="floating-btn group w-12 h-12 bg-[#0A66C2] hover:bg-[#004182] rounded-full shadow-lg flex items-center justify-center transition-all duration-300 hover:scale-110"
    aria-label="LinkedIn"
    data-aos="fade-left"
    data-aos-delay="200"
  >
    <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
    </svg>
    <span class="absolute right-14 bg-gray-900 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
      LinkedIn
    </span>
  </a>
  
  <!-- Download CV Button -->
  <a 
    href={`${baseUrl}assets/cv.pdf`}
    target="_blank"
    download="Wister-Marquez-CV.pdf"
    class="floating-btn group w-12 h-12 bg-[#ffba08] hover:bg-[#6a040f] rounded-full shadow-lg flex items-center justify-center transition-all duration-300 hover:scale-110"
    aria-label="Descargar CV"
    data-aos="fade-left"
    data-aos-delay="300"
  >
    <svg class="w-5 h-5 text-[#6a040f] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
    <span class="absolute right-14 bg-gray-900 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
      Descargar CV
    </span>
  </a>
</div>

<style>
  .floating-btn {
    animation: float 3s ease-in-out infinite;
  }
  
  .floating-btn:nth-child(2) {
    animation-delay: 0.5s;
  }
  
  .floating-btn:nth-child(3) {
    animation-delay: 1s;
  }
  
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }
  
  .floating-btn:hover {
    animation-play-state: paused;
  }
</style>

<script>
  // CV Download functionality
  document.getElementById('download-cv-btn')?.addEventListener('click', () => {
    const cvUrl = `${import.meta.env.BASE_URL || '/'}assets/cv.pdf`;
    window.open(cvUrl, '_blank');
  });
</script>
