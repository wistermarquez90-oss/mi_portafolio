---
const baseUrl = import.meta.env.BASE_URL || '/';

const navItems = [
  { href: baseUrl, label: 'Inicio' },
  { href: `${baseUrl}#sobre-mi`, label: 'Sobre Mí' },
  { href: `${baseUrl}#experiencia`, label: 'Experiencia' },
  { href: `${baseUrl}powerbi`, label: 'Power BI' },
  { 
    href: `${baseUrl}investigacion`, 
    label: 'Investigación',
    children: [
      { href: `${baseUrl}investigacion/politica-fiscal`, label: 'Política Fiscal' },
      { href: `${baseUrl}investigacion/planificacion`, label: 'Planificación Económica' },
      { href: `${baseUrl}investigacion/integracion`, label: 'Integración Económica' },
    ]
  },
  { href: `${baseUrl}blog`, label: 'Blog' },
  { href: `${baseUrl}pasantias`, label: 'Pasantías' },
  { href: `${baseUrl}ensenanza`, label: 'Enseñanza' },
  { href: `${baseUrl}contacto`, label: 'Contacto' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href={baseUrl} class="flex items-center space-x-2 group">
        <div class="w-10 h-10 bg-wine rounded-lg flex items-center justify-center group-hover:bg-gold transition-colors duration-300">
          <span class="text-white font-display font-bold text-lg group-hover:text-wine transition-colors duration-300">W</span>
        </div>
        <span class="font-display font-semibold text-white text-lg hidden sm:block nav-logo-text transition-colors duration-300 drop-shadow-md">Wister Márquez</span>
      </a>
      
      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-1">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group/nav">
              <a 
                href={item.href}
                class="px-3 py-2 text-sm font-medium text-white hover:text-[#ffba08] hover:bg-white/10 rounded-md transition-all duration-200 flex items-center gap-1 nav-link drop-shadow-md"
              >
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover/nav:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <!-- Dropdown -->
              <div class="absolute top-full left-0 mt-1 w-56 bg-[#6a040f] rounded-lg shadow-xl opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all duration-200 py-2 z-50 border border-[#ffba08]/30">
                {item.children.map((child) => (
                  <a 
                    href={child.href}
                    class="block px-4 py-2.5 text-sm text-white hover:text-[#ffba08] hover:bg-white/10 transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a 
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-white hover:text-[#ffba08] hover:bg-white/10 rounded-md transition-all duration-200 nav-link drop-shadow-md"
            >
              {item.label}
            </a>
          )
        ))}
      </div>
      
      <!-- Mobile Menu Button -->
      <button 
        id="mobile-menu-btn" 
        class="lg:hidden p-2 rounded-md text-white hover:text-[#ffba08] hover:bg-white/10 transition-colors drop-shadow-md"
        aria-label="Abrir menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-[#6a040f] border-t border-[#ffba08]/30">
    <div class="px-4 py-3 space-y-1">
      {navItems.map((item) => (
        item.children ? (
          <div class="mobile-dropdown">
            <button 
              class="mobile-dropdown-btn w-full flex items-center justify-between px-3 py-2.5 text-base font-medium text-white hover:text-[#ffba08] hover:bg-white/10 rounded-md transition-colors"
            >
              {item.label}
              <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="mobile-dropdown-content hidden pl-4 space-y-1 mt-1">
              <a 
                href={item.href}
                class="block px-3 py-2 text-sm text-white/80 hover:text-[#ffba08] hover:bg-white/5 rounded-md transition-colors"
              >
                Ver todas las asignaturas
              </a>
              {item.children.map((child) => (
                <a 
                  href={child.href}
                  class="block px-3 py-2 text-sm text-white/80 hover:text-[#ffba08] hover:bg-white/5 rounded-md transition-colors"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a 
            href={item.href}
            class="block px-3 py-2.5 text-base font-medium text-white hover:text-[#ffba08] hover:bg-white/10 rounded-md transition-colors"
          >
            {item.label}
          </a>
        )
      ))}
    </div>
  </div>
</nav>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  let lastScroll = 0;
  
  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll > 50) {
      navbar?.classList.add('bg-[#6a040f]', 'backdrop-blur-md', 'shadow-sm');
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove('bg-[#6a040f]', 'backdrop-blur-md', 'shadow-sm');
      navbar?.classList.add('bg-transparent');
    }
    
    lastScroll = currentScroll;
  });
  
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  let isMenuOpen = false;
  
  mobileMenuBtn?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    mobileMenu?.classList.toggle('hidden');
    
    // Change button color based on menu state
    if (isMenuOpen) {
      mobileMenuBtn.classList.remove('text-white', 'hover:text-[#ffba08]', 'hover:bg-white/10');
      mobileMenuBtn.classList.add('text-[#ffba08]');
    } else {
      mobileMenuBtn.classList.remove('text-[#ffba08]');
      mobileMenuBtn.classList.add('text-white', 'hover:text-[#ffba08]', 'hover:bg-white/10');
    }
    
    mobileMenuBtn.innerHTML = isMenuOpen 
      ? '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>'
      : '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>';
  });
  
  // Close mobile menu on link click
  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      isMenuOpen = false;
      mobileMenu?.classList.add('hidden');
      mobileMenuBtn.classList.remove('text-[#ffba08]');
      mobileMenuBtn.classList.add('text-white', 'hover:text-[#ffba08]', 'hover:bg-white/10');
      mobileMenuBtn.innerHTML = '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>';
    });
  });
  
  // Mobile dropdown toggle
  const mobileDropdownBtns = document.querySelectorAll('.mobile-dropdown-btn');
  mobileDropdownBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const arrow = btn.querySelector('svg');
      content.classList.toggle('hidden');
      arrow.classList.toggle('rotate-180');
    });
  });
</script>