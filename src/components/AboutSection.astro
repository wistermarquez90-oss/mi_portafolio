---
const highlights = [
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
    title: 'Análisis de Datos',
    description: 'Transformo datos complejos en insights accionables para la toma de decisiones estratégicas.'
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>',
    title: 'E-commerce',
    description: 'Gestión de ACOS y optimización de ventas en Mercado Libre, Amazon y Aliexpress.'
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>',
    title: 'Planificación',
    description: 'Experiencia en automatización de POA y gestión de sistemas financieros públicos.'
  },
  {
    icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>',
    title: 'Liderazgo',
    description: 'Coordinación nacional de finanzas en AIESEC Venezuela y Chile.'
  }
];
---

<section id="sobre-mi" class="py-20 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <!-- Image Section -->
      <div class="relative" data-aos="fade-right">
        <div class="relative z-10 bg-gradient-to-br from-wine to-wine-900 rounded-2xl p-8 lg:p-12">
          <div class="bg-white rounded-xl p-6 shadow-lg">
            <div class="flex items-center space-x-4 mb-6">
              <div class="w-16 h-16 bg-wine rounded-full flex items-center justify-center">
                <span class="font-display text-2xl font-bold text-white">WM</span>
              </div>
              <div>
                <h3 class="font-display font-bold text-xl text-gray-900">Wister Márquez</h3>
                <p class="text-gray-500">Economista | E-commerce</p>
              </div>
            </div>
            
            <div class="space-y-4">
              <div class="flex items-center space-x-3">
                <div class="w-2 h-2 bg-gold rounded-full"></div>
                <span class="text-gray-700">3+ años en E-commerce</span>
              </div>
              <div class="flex items-center space-x-3">
                <div class="w-2 h-2 bg-gold rounded-full"></div>
                <span class="text-gray-700">Certificado en Power BI</span>
              </div>
              <div class="flex items-center space-x-3">
                <div class="w-2 h-2 bg-gold rounded-full"></div>
                <span class="text-gray-700">Líder en AIESEC</span>
              </div>
              <div class="flex items-center space-x-3">
                <div class="w-2 h-2 bg-gold rounded-full"></div>
                <span class="text-gray-700">Mérida, Venezuela</span>
              </div>
            </div>
            
            <div class="mt-6 pt-6 border-t border-gray-100">
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1 bg-wine/10 text-wine text-sm rounded-full">#DataAnalytics</span>
                <span class="px-3 py-1 bg-wine/10 text-wine text-sm rounded-full">#PowerBI</span>
                <span class="px-3 py-1 bg-wine/10 text-wine text-sm rounded-full">#Ecommerce</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Decorative Elements -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-gold/20 rounded-full blur-xl"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-wine/20 rounded-full blur-xl"></div>
      </div>
      
      <!-- Content Section -->
      <div data-aos="fade-left">
        <div class="inline-block mb-4 px-4 py-1 bg-gold/10 rounded-full">
          <span class="text-wine font-medium text-sm">Sobre Mí</span>
        </div>
        
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
          Transformando datos en
          <span class="text-wine">valor estratégico</span>
        </h2>
        
        <div class="prose prose-lg text-gray-600 mb-8">
          <p class="mb-4">
            Soy un economista en formación con pasión por el análisis de datos y el comercio electrónico. 
            Mi experiencia combina el rigor académico con la aplicación práctica en entornos empresariales reales.
          </p>
          
          <p class="mb-4">
            Como Digital Trade Manager en Morekashop, he desarrollado habilidades especializadas en la 
            gestión de marketplaces y el control de métricas clave como el ACOS. Mi trabajo se centra 
            en maximizar el ROI mediante decisiones basadas en datos.
          </p>
          
          <p>
            Mi formación en planificación económica y política fiscal, combinada con mi experiencia 
            liderando equipos en AIESEC, me ha permitido desarrollar una visión integral de los negocios 
            y la capacidad de trabajar en entornos multiculturales.
          </p>
        </div>
        
        <a 
          href="/contacto"
          class="inline-flex items-center px-6 py-3 bg-wine text-white font-semibold rounded-lg hover:bg-wine-800 transition-colors duration-200 group"
        >
          Hablemos
          <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
    
    <!-- Highlights Grid -->
    <div class="mt-20 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {highlights.map((item, index) => (
        <div 
          class="group p-6 bg-gray-50 rounded-xl hover:bg-wine transition-colors duration-300"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="w-12 h-12 bg-wine/10 group-hover:bg-gold/20 rounded-lg flex items-center justify-center mb-4 transition-colors duration-300">
            <div class="text-wine group-hover:text-gold transition-colors duration-300">
              <Fragment set:html={item.icon} />
            </div>
          </div>
          
          <h3 class="font-display font-semibold text-lg text-gray-900 group-hover:text-white mb-2 transition-colors duration-300">
            {item.title}
          </h3>
          
          <p class="text-gray-600 group-hover:text-wine-100 text-sm transition-colors duration-300">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
